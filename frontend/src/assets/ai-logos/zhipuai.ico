le\":\"\",\"text\":\"+886-277083288 (Taiwan, China)\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"+86-1021377168 (Global)\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"+1-2087016888 (United States)\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"Conference Password: \",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"074283\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"type\":\"heading\",\"version\":1,\"tag\":\"h2\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"Registration is required for participation. Participants are kindly requested to register in advance via the links above or by scanning the QR code on the event poster.\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"69c9f6202194f7fe0c10c8d2\",\"fields\":null,\"relationTo\":\"media\",\"value\":\"$23:props:newsItems:1:content_zh:root:children:19:value\"},{\"children\":[],\"direction\":null,\"format\":\"\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"}],\"direction\":null,\"format\":\"\",\"indent\":0,\"type\":\"root\",\"version\":1}},\"featured\":true,\"thumbnail_zh\":\"/api/media/file/adc01bf14fc5c07b3eb236686d904ee0.png\",\"thumbnail_en\":\"/api/media/file/adc01bf14fc5c07b3eb236686d904ee0-1.png\",\"active\":true,\"order\":0,\"tag_zh\":[],\"tag_en\":[],\"apiConfig_zh\":null,\"apiConfig_en\":null,\"experienceUrl_zh\":null,\"experienceUrl_en\":null,\"updatedAt\":\"2026-03-30T04:26:10.777Z\",\"createdAt\":\"2026-03-30T04:02:26.650Z\"},{\"id\":97,\"title_zh\":\"中关村自主大模型产业联盟第一次会员大会 结果公示\",\"title_en\":null,\"createAt\":\"2025-08-25T06:56:41.718Z\",\"category\":\"news\",\"resume_zh\":\"2025年8月19日，中关村自主大模型产业联盟在北京市海淀区搜狐网络大厦10层图灵会议室召开了第一次会员大会。会议应出席会员（均为单位会员，下同）数32，实到数32，超过会员总数2/3，会议有效。会议由北京智谱华章科技股份有限公司董事长刘德兵主持。会议主要内容和通过的主要决定如下：一、会员以举手方式表决通过了《中关村自主大模型产业联盟筹备工作报告》、《中关村自主大模型产业联盟章程（草案）》、《中关\",\"resume_en\":\"2025年8月19日，中关村自主大模型产业联盟在北京市海淀区搜狐网络大厦10层图灵会议室召开了第一次会员大会。会议应出席会员（均为单位会员，下同）数32，实到数32，超过会员总数2/3，会议有效。会议由北京智谱华章科技股份有限公司董事长刘德兵主持。会议主要内容和通过的主要决定如下：一、会员以举手方式表决通过了《中关村自主大模型产业联盟筹备工作报告》、《中关村自主大模型产业联盟章程（草案）》、《中关\",\"contentType_zh\":\"content\",\"externalUrl_zh\":null,\"content_zh\":{\"root\":{\"type\":\"root\",\"children\":[{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"2025\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"年8月19日，中关村自主大模型产业联盟在北京市海淀区搜狐网络大厦10层图灵会议室召开了第一次会员大会。会议应出席会员（均为单位会员，下同）数32，实到数32，超过会员总数2/3，会议有效。会议由北京智谱华章科技股份有限公司董事长刘德兵主持。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"会议主要内容和通过的主要决定如下：\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"一、会员以举手方式表决通过了《中关村自主大模型产业联盟筹备工作报告》、《中关村自主大模型产业联盟章程（草案）》、《中关村自主大模型产业联盟第一次会员大会选举办法》（含理事会和监事会选举办法）。同意32票，反对0票，弃权0票，同意票数超过到会会员人数2/3。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"二、会员以无记名投票的方式表决通过了《中关村自主大模型产业联盟会费收取管理办法》。发出选票32张，收回选票32张，同意32票，反对0票，弃权0票，同意票数超过到会会员人数1/2。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"三、会员以无记名投票的方式选举产生了第一届理事会，理事会成员7名，无北京市纪委、市委组织部《关于从严做好清理规范领导干部在社会团体、基金会、民办非企业单位等社会组织以及在企业兼职有关工作的通知》（京组通[2017]20号）中规定的现职领导干部。发出选票32张，收回选票32张，同意32票，反对0票，弃权0票，同意票数超过到会会员人数2/3。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"理事会成员名单如下：清华大学；北京智谱华章科技股份有限公司；北京嘀嘀无限科技发展有限公司；北京智源人工智能研究院；中国科学院计算技术研究所；京能数字产业有限公司；摩尔线程智能科技（北京）股份有限公司。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"四、会员以无记名投票的方式选举产生了监事会，监事会成员3名。发出选票32张，收回选票32张，同意32票，反对0票，弃权0票，同意票数超过到会会员人数2/3。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"监事会成员名单如下：北京并行科技股份有限公司；北京生数科技有限公司；北京彩智科技有限公司。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"五、理事会以无记名投票方式选举产生了负责人（括号内为单位代表人）。理事长：清华大学（计算机科学与技术系教授唐杰）。秘书长：北京智谱华章科技股份有限公司（董事长刘德兵）。法定代表人由刘德兵担任。理事会发出选票7张，收回选票7张，同意7票，反对0票，弃权0票，同意票数达到到会理事数的2/3以上。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"六、监事会以无记名投票方式选举产生了监事长（括号内为单位代表人），监事长：北京并行科技股份有限公司（董事长陈健）。发出选票3张，收回选票3张，同意3票，反对0票，弃权0票，同意票数达到到会监事数的2/3以上。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"（以下无正文）\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"313cfcaca0217caad9160f\",\"fields\":null,\"relationTo\":\"media\",\"value\":{\"id\":313,\"alt\":\"98ba2733-fdd6-4c21-9274-930c0e72a20c.jpg\",\"updatedAt\":\"2025-12-26T15:20:08.000Z\",\"createdAt\":\"2025-12-26T15:20:08.000Z\",\"url\":\"/api/media/file/django-summernote-2025-08-25-98ba2733-fdd6-4c21-9274-930c0e72a20c.jpg\",\"thumbnailURL\":null,\"filename\":\"django-summernote-2025-08-25-98ba2733-fdd6-4c21-9274-930c0e72a20c.jpg\",\"mimeType\":\"image/jpeg\",\"filesize\":86342,\"width\":1132,\"height\":1616,\"focalX\":null,\"focalY\":null}}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1}},\"contentType_en\":\"content\",\"externalUrl_en\":null,\"content_en\":{\"root\":{\"type\":\"root\",\"children\":[{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"2025\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"年8月19日，中关村自主大模型产业联盟在北京市海淀区搜狐网络大厦10层图灵会议室召开了第一次会员大会。会议应出席会员（均为单位会员，下同）数32，实到数32，超过会员总数2/3，会议有效。会议由北京智谱华章科技股份有限公司董事长刘德兵主持。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"会议主要内容和通过的主要决定如下：\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"一、会员以举手方式表决通过了《中关村自主大模型产业联盟筹备工作报告》、《中关村自主大模型产业联盟章程（草案）》、《中关村自主大模型产业联盟第一次会员大会选举办法》（含理事会和监事会选举办法）。同意32票，反对0票，弃权0票，同意票数超过到会会员人数2/3。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"二、会员以无记名投票的方式表决通过了《中关村自主大模型产业联盟会费收取管理办法》。发出选票32张，收回选票32张，同意32票，反对0票，弃权0票，同意票数超过到会会员人数1/2。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"三、会员以无记名投票的方式选举产生了第一届理事会，理事会成员7名，无北京市纪委、市委组织部《关于从严做好清理规范领导干部在社会团体、基金会、民办非企业单位等社会组织以及在企业兼职有关工作的通知》（京组通[2017]20号）中规定的现职领导干部。发出选票32张，收回选票32张，同意32票，反对0票，弃权0票，同意票数超过到会会员人数2/3。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"理事会成员名单如下：清华大学；北京智谱华章科技股份有限公司；北京嘀嘀无限科技发展有限公司；北京智源人工智能研究院；中国科学院计算技术研究所；京能数字产业有限公司；摩尔线程智能科技（北京）股份有限公司。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"四、会员以无记名投票的方式选举产生了监事会，监事会成员3名。发出选票32张，收回选票32张，同意32票，反对0票，弃权0票，同意票数超过到会会员人数2/3。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"监事会成员名单如下：北京并行科技股份有限公司；北京生数科技有限公司；北京彩智科技有限公司。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"五、理事会以无记名投票方式选举产生了负责人（括号内为单位代表人）。理事长：清华大学（计算机科学与技术系教授唐杰）。秘书长：北京智谱华章科技股份有限公司（董事长刘德兵）。法定代表人由刘德兵担任。理事会发出选票7张，收回选票7张，同意7票，反对0票，弃权0票，同意票数达到到会理事数的2/3以上。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"六、监事会以无记名投票方式选举产生了监事长（括号内为单位代表人），监事长：北京并行科技股份有限公司（董事长陈健）。发出选票3张，收回选票3张，同意3票，反对0票，弃权0票，同意票数达到到会监事数的2/3以上。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"（以下无正文）\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"313cfcaca0217caad9160f\",\"fields\":null,\"relationTo\":\"media\",\"value\":\"$23:props:newsItems:2:content_zh:root:children:11:value\"}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1}},\"featured\":true,\"thumbnail_zh\":\"/api/media/file/%E5%BE%AE%E4%BF%A1%E5%9B%BE%E7%89%87_20250825105102_1559_aLl85pZ.jpg\",\"thumbnail_en\":\"/api/media/file/%E5%BE%AE%E4%BF%A1%E5%9B%BE%E7%89%87_20250825105102_1559_aLl85pZ.jpg\",\"active\":true,\"order\":0,\"tag_zh\":[],\"tag_en\":[],\"apiConfig_zh\":null,\"apiConfig_en\":null,\"experienceUrl_zh\":null,\"experienceUrl_en\":null,\"updatedAt\":\"2026-01-07T11:45:18.781Z\",\"createdAt\":\"2025-08-25T06:56:41.718Z\"},{\"id\":76,\"title_zh\":\"GLM-PC 基座模型，CogAgent-9B 开源\",\"title_en\":null,\"createAt\":\"2024-12-30T10:44:30.887Z\",\"category\":\"news\",\"resume_zh\":\"11 月 29 日，智谱正式提出 GLM-OS 概念，并发布 AutoGLM 和 GLM-PC 两款 Agent 产品。为推动大模型 Agent 生态发展，我们决定将 GLM-PC 的基座模型——CogAgent-9B 开源，供社区进一步开发。CogAgent-9B-20241220是基于 GLM-4V-9B 训练而成的专用 Agent 任务模型。该模型仅需屏幕截图作为输入（无需 HTML 等文本\",\"resume_en\":\"11 月 29 日，智谱正式提出 GLM-OS 概念，并发布 AutoGLM 和 GLM-PC 两款 Agent 产品。为推动大模型 Agent 生态发展，我们决定将 GLM-PC 的基座模型——CogAgent-9B 开源，供社区进一步开发。CogAgent-9B-20241220是基于 GLM-4V-9B 训练而成的专用 Agent 任务模型。该模型仅需屏幕截图作为输入（无需 HTML 等文本\",\"contentType_zh\":\"content\",\"externalUrl_zh\":null,\"content_zh\":{\"root\":{\"type\":\"root\",\"children\":[{\"type\":\"image\",\"value\":{\"url\":\"https://zhipu-ai.feishu.cn/space/api/box/stream/download/asynccode/?code=MGM3M2VlYWQyYzI2NjFlMGQ0YmMzYTg4NjZjNGI0NWVfUUMyd0M0ODlBenJvdTM2OXRwbElrTXFBVUhmTG5tZ09fVG9rZW46QzlHSmJ4Mzk0b2pZanl4MmZ6YWN2dDJObkVoXzE3MzU1NTUzOTE6MTczNTU1ODk5MV9WNA\",\"alt\":\"\",\"mimeType\":\"image/jpeg\"}},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"11 月 29 日，智谱正式提出 GLM-OS 概念，并发布 AutoGLM 和 GLM-PC 两款 Agent 产品。为推动大模型 Agent 生态发展，我们决定将 GLM-PC 的基座模型——CogAgent-9B 开源，供社区进一步开发。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"CogAgent-9B-20241220\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"是基于 GLM-4V-9B 训练而成的专用 Agent 任务模型。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"该模型仅需屏幕截图作为输入（无需 HTML 等文本表征），便能根据用户指定的任意任务，结合历史操作，预测下一步的 GUI 操作。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"得益于屏幕截图和 GUI 操作的普适性，CogAgent 可广泛应用于各类基于 GUI 交互的场景，如个人电脑、手机、车机设备等。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"相较于 2023 年 12 月开源的第一版 CogAgent 模型，CogAgent-9B-20241220 在 GUI 感知、推理预测准确性、动作空间完善性、任务普适性和泛化性等方面均实现了显著提升，并支持中英文双语的屏幕截图和语言交互。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"heading\",\"tag\":\"h1\",\"children\":[{\"type\":\"text\",\"text\":\"CogAgent-9B\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"论文：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"list\",\"tag\":\"ul\",\"children\":[{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"https://arxiv.org/abs/2312.08914\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"代码：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"list\",\"tag\":\"ul\",\"children\":[{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"https://github.com/THUDM/CogAgent\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"模型：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"list\",\"tag\":\"ul\",\"children\":[{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"Huggingface: https://huggingface.co/THUDM/cogagent-9b-20241220\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"魔搭社区：https://modelscope.cn/models/ZhipuAI/cogagent-9b-20241220（方便下载）\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"魔乐社区：https://modelers.cn/models/zhipuai/cogagent-9b-20241220（适配昇腾卡）\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"技术文档：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"list\",\"tag\":\"ul\",\"children\":[{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"https://cogagent.aminer.cn/blog#/articles/cogagent-9b-20241220-technical-report\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"heading\",\"tag\":\"h2\",\"children\":[{\"type\":\"text\",\"text\":\"执行过程\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"image\",\"value\":{\"url\":\"https://zhipu-ai.feishu.cn/space/api/box/stream/download/asynccode/?code=NzA3N2M2NDgxYjUzZWIzOGRlZGVkZjA4NWYzNWZhMzNfN1FjSVlCYUJqUlZiMVhnZVZDTTY2cElGTVZaZkpYRm1fVG9rZW46QWZZQmJRNTRpb2cyMnp4TzV6WGNsOUxXbktmXzE3MzU1NTUzOTE6MTczNTU1ODk5MV9WNA\",\"alt\":\"\",\"mimeType\":\"image/jpeg\"}},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"CogAgent 以 GUI 截图为唯一环境输入，结合已完成的动作历史，计算当前 GUI 截图中最合适的动作。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"该动作通过 CogAgent 端侧应用（如 GLM-PC 和 CogAgent Demo App）注入 GUI，GUI 响应并更新图像内容；\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"同时，该动作被添加至动作历史。CogAgent 根据更新后的历史动作和截图，计算后续操作。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"此过程循环往复，直至 CogAgent 判定指令执行完毕。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"CogAgent 的输入仅包含三部分：用户的自然语言指令、已执行历史动作记录和 GUI 截图，无需任何文本形式表征的布局信息或附加元素标签（set of marks）信息。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"其输出涵盖以下四个方面：\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"list\",\"tag\":\"ul\",\"children\":[{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"思考过程（Status \u0026 Plan）：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"CogAgent 显式输出理解 GUI 截图和决定下一步操作的思考过程，包括状态（Status）和计划（Plan）两部分，输出内容可通过参数控制。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"下一步动作的自然语言描述（Action）：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"自然语言形式的动作描述将被加入历史操作记录，便于模型理解已执行的动作步骤。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"下一步动作的结构化描述（Grounded Operation）：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"CogAgent 以类似函数调用的形式，结构化地描述下一步操作及其参数，便于端侧应用解析并执行模型输出。其动作空间包含 GUI 操作（基础动作，如左键单击、文本输入等）和拟人行为（高级动作，如应用启动、调用语言模型等）两类。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"下一步动作的敏感性判断：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"动作分为“一般操作”和“敏感操作”两类，后者指可能带来难以挽回后果的动作，例如在“发送邮件”任务中点击“发送”按钮。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"heading\",\"tag\":\"h2\",\"children\":[{\"type\":\"text\",\"text\":\"模型升级\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"image\",\"value\":{\"url\":\"https://zhipu-ai.feishu.cn/space/api/box/stream/download/asynccode/?code=Njg0MTFjYjdkYmYwNTg2MjM2YmRhZTFiNGExZjRmNTBfMmRTenAxNkRHbXFtOVlCVTNFZkxIak1qT2gyMVhpSkpfVG9rZW46UGlFdWJSZkpDb1ZGbTF4a3NsY2NlNkhkbnNiXzE3MzU1NTUzOTE6MTczNTU1ODk5MV9WNA\",\"alt\":\"\",\"mimeType\":\"image/jpeg\"}},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"模型基座与结构升级：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"我们采用了更强大的视觉语言模型\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"GLM-4V-9B 作为基座\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"，显著提升了模型的图像理解性能。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"视觉处理模块优化：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"实现了更高效、统一的视觉处理模块，\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"支持 1120*1120 原生高分辨率图像输入\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"。通过带参数的下采样方法，在几乎不损失模型能力的前提下，提高了模型效率。CogAgent 在结构上支持任意比例或大小的图像输入，但在训练和推理中，统一将输入图像缩放到 1120*1120。尽管输入图像尺寸固定，测试结果显示，即使在 2K 或更高分辨率的屏幕上，模型仍能保持准确的理解能力。为获得更佳表现，建议用户适当增加图标和文字的相对大小，确保缩放后截图中的内容清晰可辨。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"数据集丰富与完善：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"广泛收集并整合了多种数据集，\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"包括无监督数据和 GUI 指令微调数据集\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"。无监督数据涵盖开源 GUI 布局数据集、自采集的应用和网页数据集；GUI 指令微调数据集则包含更长链路、更多应用、跨应用的 GUI agent 任务数据集等。此外，利用 CogAgent 自我生成数据，进一步扩充和完善了数据集。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"预训练策略优化：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"VLM 和 GUI 预训练旨在提升模型对视觉输入和 GUI 界面的基础理解能力。我们\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"首次提出了 GUI Grounding 预训练\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"，利用屏幕截图和布局对，构建界面子区域与布局表征（如 DOM 元素）的对应关系，从而构造 GUI 的 REG 和 REC 任务：\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"list\",\"tag\":\"ul\",\"children\":[{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"GUI Referring Expression Generation （REG）：预测截图上某一区域对应的布局表征。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"GUI Referring Expression Comprehension （REC）：预测截图中某一元素对应的位置。此方法已应用于多个 GUI 理解数据构造和 GUI agent 工作中。在原论文中，我们使用 40 万网页数据，构造了 1.4 亿的 REC \u0026 REG 训练样本。在此基础上，进一步扩充和优化了训练数据，加入了桌面应用和移动应用的布局数据，使模型更适应实际应用场景。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"后训练策略改进：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"后训练在提升模型 GUI agent 分析、推理、预测能力方面至关重要。我们采用了更科学的后训练策略，分为两个难度递进的阶段：\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"list\",\"tag\":\"ul\",\"children\":[{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"GUI instruction tuning：融合 GUI 相关多任务数据，深化模型对 GUI 内容和功能的理解，具备初步问答能力。使用了广泛的开源数据和私有收集数据。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"GUI agent SFT：使模型具备完善的 GUI agent 推理能力，训练数据包括开源数据集（如 Mind2Web）和额外收集的多平台跨应用数据。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"模型推理及思维链优化：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"将思维链分解为 Status（当前屏幕状态）、Plan（全局计划）、Action（下一步自然语言描述）、Operation（下一步形式语言描述）\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"。通过随机采样混合多种模式训练数据（如 Action-Operation、Status-Action-Operation 等），可根据交互情景、计算资源和准确率需求灵活调整和控制推理过程中的实际输出。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"动作空间完善：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"明确了基础动作空间\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"，并新增了 LLM、QUOTE_TEXT、LAUNCH 等高级动作，增强了模型的使用工具和交互能力。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"heading\",\"tag\":\"h2\",\"children\":[{\"type\":\"text\",\"text\":\"评测结果\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"我们在以下四个数据集中测试了 CogAgent-9B-20241220 和类似模型的性能。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"image\",\"value\":{\"url\":\"https://zhipu-ai.feishu.cn/space/api/box/stream/download/asynccode/?code=MTU3N2I1ZWQxOGJhZjk1YmRkMjBhOWQ1NTliN2Y2OTFfbmpGNlhSOWRmOTUwcmNWd1MxaldKM3dCQVRTdjcweGJfVG9rZW46RFRScWJlQ0Vxb2dxaWV4ZDF0OGNPc3NObnllXzE3MzU1NTUzOTE6MTczNTU1ODk5MV9WNA\",\"alt\":\"\",\"mimeType\":\"image/jpeg\"}},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"我们对比了基于 API 的商业模型（GPT-4o-20240806、Claude-3.5-Sonnet）、\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"商业 API + GUI Grounding 模型（GPT-4o + UGround、GPT-4o + OS-ATLAS）、\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"开源 GUI Agent 模型（Qwen2-VL、ShowUI、SeeClick）。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"结果表明，CogAgent 在 GUI 定位（Screenspot）、单步操作（OmniAct）、中文 step-wise 榜单（CogAgentBench-basic-cn）、多步操作（OSWorld）都取得了领先的结果，仅在 OSworld 上略逊于针对 Computer Use 特化的 Claude-3.5-Sonnet 和结合外接 GUI Grounding Model 的 GPT-4o。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1}},\"contentType_en\":\"content\",\"externalUrl_en\":null,\"content_en\":{\"root\":{\"type\":\"root\",\"children\":[{\"type\":\"image\",\"value\":{\"url\":\"https://zhipu-ai.feishu.cn/space/api/box/stream/download/asynccode/?code=MGM3M2VlYWQyYzI2NjFlMGQ0YmMzYTg4NjZjNGI0NWVfUUMyd0M0ODlBenJvdTM2OXRwbElrTXFBVUhmTG5tZ09fVG9rZW46QzlHSmJ4Mzk0b2pZanl4MmZ6YWN2dDJObkVoXzE3MzU1NTUzOTE6MTczNTU1ODk5MV9WNA\",\"alt\":\"\",\"mimeType\":\"image/jpeg\"}},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"11 月 29 日，智谱正式提出 GLM-OS 概念，并发布 AutoGLM 和 GLM-PC 两款 Agent 产品。为推动大模型 Agent 生态发展，我们决定将 GLM-PC 的基座模型——CogAgent-9B 开源，供社区进一步开发。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"CogAgent-9B-20241220\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"是基于 GLM-4V-9B 训练而成的专用 Agent 任务模型。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"该模型仅需屏幕截图作为输入（无需 HTML 等文本表征），便能根据用户指定的任意任务，结合历史操作，预测下一步的 GUI 操作。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"得益于屏幕截图和 GUI 操作的普适性，CogAgent 可广泛应用于各类基于 GUI 交互的场景，如个人电脑、手机、车机设备等。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"相较于 2023 年 12 月开源的第一版 CogAgent 模型，CogAgent-9B-20241220 在 GUI 感知、推理预测准确性、动作空间完善性、任务普适性和泛化性等方面均实现了显著提升，并支持中英文双语的屏幕截图和语言交互。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"heading\",\"tag\":\"h1\",\"children\":[{\"type\":\"text\",\"text\":\"CogAgent-9B\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"论文：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"list\",\"tag\":\"ul\",\"children\":[{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"https://arxiv.org/abs/2312.08914\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"代码：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"list\",\"tag\":\"ul\",\"children\":[{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"https://github.com/THUDM/CogAgent\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"模型：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"list\",\"tag\":\"ul\",\"children\":[{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"Huggingface: https://huggingface.co/THUDM/cogagent-9b-20241220\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"魔搭社区：https://modelscope.cn/models/ZhipuAI/cogagent-9b-20241220（方便下载）\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"魔乐社区：https://modelers.cn/models/zhipuai/cogagent-9b-20241220（适配昇腾卡）\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"技术文档：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"list\",\"tag\":\"ul\",\"children\":[{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"https://cogagent.aminer.cn/blog#/articles/cogagent-9b-20241220-technical-report\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"heading\",\"tag\":\"h2\",\"children\":[{\"type\":\"text\",\"text\":\"执行过程\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"image\",\"value\":{\"url\":\"https://zhipu-ai.feishu.cn/space/api/box/stream/download/asynccode/?code=NzA3N2M2NDgxYjUzZWIzOGRlZGVkZjA4NWYzNWZhMzNfN1FjSVlCYUJqUlZiMVhnZVZDTTY2cElGTVZaZkpYRm1fVG9rZW46QWZZQmJRNTRpb2cyMnp4TzV6WGNsOUxXbktmXzE3MzU1NTUzOTE6MTczNTU1ODk5MV9WNA\",\"alt\":\"\",\"mimeType\":\"image/jpeg\"}},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"CogAgent 以 GUI 截图为唯一环境输入，结合已完成的动作历史，计算当前 GUI 截图中最合适的动作。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"该动作通过 CogAgent 端侧应用（如 GLM-PC 和 CogAgent Demo App）注入 GUI，GUI 响应并更新图像内容；\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"同时，该动作被添加至动作历史。CogAgent 根据更新后的历史动作和截图，计算后续操作。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"此过程循环往复，直至 CogAgent 判定指令执行完毕。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"CogAgent 的输入仅包含三部分：用户的自然语言指令、已执行历史动作记录和 GUI 截图，无需任何文本形式表征的布局信息或附加元素标签（set of marks）信息。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"其输出涵盖以下四个方面：\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"list\",\"tag\":\"ul\",\"children\":[{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"思考过程（Status \u0026 Plan）：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"CogAgent 显式输出理解 GUI 截图和决定下一步操作的思考过程，包括状态（Status）和计划（Plan）两部分，输出内容可通过参数控制。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"下一步动作的自然语言描述（Action）：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"自然语言形式的动作描述将被加入历史操作记录，便于模型理解已执行的动作步骤。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"下一步动作的结构化描述（Grounded Operation）：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"CogAgent 以类似函数调用的形式，结构化地描述下一步操作及其参数，便于端侧应用解析并执行模型输出。其动作空间包含 GUI 操作（基础动作，如左键单击、文本输入等）和拟人行为（高级动作，如应用启动、调用语言模型等）两类。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"下一步动作的敏感性判断：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"动作分为“一般操作”和“敏感操作”两类，后者指可能带来难以挽回后果的动作，例如在“发送邮件”任务中点击“发送”按钮。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"heading\",\"tag\":\"h2\",\"children\":[{\"type\":\"text\",\"text\":\"模型升级\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"image\",\"value\":{\"url\":\"https://zhipu-ai.feishu.cn/space/api/box/stream/download/asynccode/?code=Njg0MTFjYjdkYmYwNTg2MjM2YmRhZTFiNGExZjRmNTBfMmRTenAxNkRHbXFtOVlCVTNFZkxIak1qT2gyMVhpSkpfVG9rZW46UGlFdWJSZkpDb1ZGbTF4a3NsY2NlNkhkbnNiXzE3MzU1NTUzOTE6MTczNTU1ODk5MV9WNA\",\"alt\":\"\",\"mimeType\":\"image/jpeg\"}},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"模型基座与结构升级：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"我们采用了更强大的视觉语言模型\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"GLM-4V-9B 作为基座\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"，显著提升了模型的图像理解性能。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"视觉处理模块优化：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"实现了更高效、统一的视觉处理模块，\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"支持 1120*1120 原生高分辨率图像输入\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"。通过带参数的下采样方法，在几乎不损失模型能力的前提下，提高了模型效率。CogAgent 在结构上支持任意比例或大小的图像输入，但在训练和推理中，统一将输入图像缩放到 1120*1120。尽管输入图像尺寸固定，测试结果显示，即使在 2K 或更高分辨率的屏幕上，模型仍能保持准确的理解能力。为获得更佳表现，建议用户适当增加图标和文字的相对大小，确保缩放后截图中的内容清晰可辨。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"数据集丰富与完善：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"广泛收集并整合了多种数据集，\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"包括无监督数据和 GUI 指令微调数据集\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"。无监督数据涵盖开源 GUI 布局数据集、自采集的应用和网页数据集；GUI 指令微调数据集则包含更长链路、更多应用、跨应用的 GUI agent 任务数据集等。此外，利用 CogAgent 自我生成数据，进一步扩充和完善了数据集。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"预训练策略优化：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"VLM 和 GUI 预训练旨在提升模型对视觉输入和 GUI 界面的基础理解能力。我们\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"首次提出了 GUI Grounding 预训练\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"，利用屏幕截图和布局对，构建界面子区域与布局表征（如 DOM 元素）的对应关系，从而构造 GUI 的 REG 和 REC 任务：\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"list\",\"tag\":\"ul\",\"children\":[{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"GUI Referring Expression Generation （REG）：预测截图上某一区域对应的布局表征。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"GUI Referring Expression Comprehension （REC）：预测截图中某一元素对应的位置。此方法已应用于多个 GUI 理解数据构造和 GUI agent 工作中。在原论文中，我们使用 40 万网页数据，构造了 1.4 亿的 REC \u0026 REG 训练样本。在此基础上，进一步扩充和优化了训练数据，加入了桌面应用和移动应用的布局数据，使模型更适应实际应用场景。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"后训练策略改进：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"后训练在提升模型 GUI agent 分析、推理、预测能力方面至关重要。我们采用了更科学的后训练策略，分为两个难度递进的阶段：\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"list\",\"tag\":\"ul\",\"children\":[{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"GUI instruction tuning：融合 GUI 相关多任务数据，深化模型对 GUI 内容和功能的理解，具备初步问答能力。使用了广泛的开源数据和私有收集数据。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"GUI agent SFT：使模型具备完善的 GUI agent 推理能力，训练数据包括开源数据集（如 Mind2Web）和额外收集的多平台跨应用数据。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"模型推理及思维链优化：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"将思维链分解为 Status（当前屏幕状态）、Plan（全局计划）、Action（下一步自然语言描述）、Operation（下一步形式语言描述）\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"。通过随机采样混合多种模式训练数据（如 Action-Operation、Status-Action-Operation 等），可根据交互情景、计算资源和准确率需求灵活调整和控制推理过程中的实际输出。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"动作空间完善：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"明确了基础动作空间\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"，并新增了 LLM、QUOTE_TEXT、LAUNCH 等高级动作，增强了模型的使用工具和交互能力。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"heading\",\"tag\":\"h2\",\"children\":[{\"type\":\"text\",\"text\":\"评测结果\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"我们在以下四个数据集中测试了 CogAgent-9B-20241220 和类似模型的性能。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"image\",\"value\":{\"url\":\"https://zhipu-ai.feishu.cn/space/api/box/stream/download/asynccode/?code=MTU3N2I1ZWQxOGJhZjk1YmRkMjBhOWQ1NTliN2Y2OTFfbmpGNlhSOWRmOTUwcmNWd1MxaldKM3dCQVRTdjcweGJfVG9rZW46RFRScWJlQ0Vxb2dxaWV4ZDF0OGNPc3NObnllXzE3MzU1NTUzOTE6MTczNTU1ODk5MV9WNA\",\"alt\":\"\",\"mimeType\":\"image/jpeg\"}},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"我们对比了基于 API 的商业模型（GPT-4o-20240806、Claude-3.5-Sonnet）、\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"商业 API + GUI Grounding 模型（GPT-4o + UGround、GPT-4o + OS-ATLAS）、\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"开源 GUI Agent 模型（Qwen2-VL、ShowUI、SeeClick）。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"结果表明，CogAgent 在 GUI 定位（Screenspot）、单步操作（OmniAct）、中文 step-wise 榜单（CogAgentBench-basic-cn）、多步操作（OSWorld）都取得了领先的结果，仅在 OSworld 上略逊于针对 Computer Use 特化的 Claude-3.5-Sonnet 和结合外接 GUI Grounding Model 的 GPT-4o。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1}},\"featured\":true,\"thumbnail_zh\":\"/api/media/file/image_3.png\",\"thumbnail_en\":\"/api/media/file/image_3.png\",\"active\":true,\"order\":0,\"tag_zh\":[\"模型\"],\"tag_en\":[],\"apiConfig_zh\":null,\"apiConfig_en\":null,\"experienceUrl_zh\":null,\"experienceUrl_en\":null,\"updatedAt\":\"2026-01-07T11:45:18.886Z\",\"createdAt\":\"2024-12-30T10:44:30.887Z\"},{\"id\":68,\"title_zh\":\"Agent 新进展：跨 app、跨设备、更多玩法｜智谱 Agent OpenDay\",\"title_en\":null,\"createAt\":\"2024-11-28T07:38:03.621Z\",\"category\":\"news\",\"resume_zh\":\"人类与机器的互动方式正在发生范式转变——这是由于只有对话功能的 Chatbot，正在进化为“有手、有脑、有眼睛”的自主 Agent。作为最早探索 Agent 的大模型企业之一，智谱今天带来了多个新进展：AutoGLM 可以自主执行超过 50 步的长步骤操作，也可以跨 app 执行任务AutoGLM开启「全自动」上网新体验，支持等数十个网站的无人驾驶像人一样操作计算机的GLM-PC 启动内测，基于视\",\"resume_en\":\"人类与机器的互动方式正在发生范式转变——这是由于只有对话功能的 Chatbot，正在进化为“有手、有脑、有眼睛”的自主 Agent。作为最早探索 Agent 的大模型企业之一，智谱今天带来了多个新进展：AutoGLM 可以自主执行超过 50 步的长步骤操作，也可以跨 app 执行任务AutoGLM开启「全自动」上网新体验，支持等数十个网站的无人驾驶像人一样操作计算机的GLM-PC 启动内测，基于视\",\"contentType_zh\":\"content\",\"externalUrl_zh\":null,\"content_zh\":{\"root\":{\"type\":\"root\",\"children\":[{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"人类与机器的互动方式正在发生范式转变——这是由于只有对话功能的 Chatbot，正在进化为“有手、有脑、有眼睛”的自主 Agent。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"作为最早探索 Agent 的大模型企业之一，智谱今天带来了多个新进展：\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"list\",\"tag\":\"ul\",\"children\":[{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"AutoGLM 可以自主执行超过 50 步的长步骤操作，也可以跨 app 执行任务\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"AutoGLM开启「全自动」上网新体验，支持等数十个网站的无人驾驶\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"像人一样操作计算机的GLM-PC 启动内测，基于视觉多模态模型实现通用Agent的技术探索\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"在 OpenDay 现场，AutoGLM 给在场数百位嘉宾发送了\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"「AI给人类发的第一个红包」\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"，并且手机远程指挥电脑自动发送文件。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"而智谱 CEO 张鹏需要做的，只是在现场下达一个简单语音指令。这些原本对于机器而言非常复杂的操作，今天完全由智谱产品化的 Agent 完成。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"AutoGLM挑战更复杂\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"新升级的 AutoGLM 可以挑战完成复杂任务：\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"list\",\"tag\":\"ul\",\"children\":[{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"超长任务\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"：理解超长指令，执行超长任务。并且，在这种多步、循环任务中，AutoGLM 的速度表现超过人手动操作。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"跨App：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"AutoGLM 支持跨 App 来执行任务。由于目前 AutoGLM 形态更像是用户和应用间的APP执行的调度层，因此跨 App 能力是里面非常关键的一步。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"短口令：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"AutoGLM 能支持长任务的自定义短语。今天不用再给 AutoGLM 说：“帮我买一杯瑞幸咖啡，生椰拿铁，五道口店，大杯、热、微糖” ，只需要说“点咖啡”。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"随便模式：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"我们都会陷入选择恐惧，AutoGLM 今天可以主动帮你做出决策。随便模式下所有步骤都让 AI 决策，带来有抽盲盒式的惊喜。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"同时 AutoGLM 启动大规模百万内测，并将尽快上线成为面向 C 端用户的产品。AutoGLM 同时宣布启动\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"「10个亿级 APP 免费 Auto 升级」\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"的计划，邀请 App 伙伴联合探索自己的 Auto 新场景。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"支持核心场景和核心应用的 AutoGLM 标品 API，即将上线到智谱 maas 开放平台（bigmodel.cn）试用。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"Web 端开启「全自动」上网新体验\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"：智谱清言插件上线 AutoGLM 功能，支持搜索、微博、知乎、Github 等数十个网站的无人驾驶。在现场demo里，清言插件自动完成了“在百度搜索芒果tv，打开小巷人家，播放最新一集，发弹幕结局打卡”。全程没有人的干预。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"一次「无人驾驶」的\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"技术探索\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"不只是基于手机和浏览器，智谱还带来基于 PC 的自主Agent。GLM-PC 是 GLM 团队面向「无人驾驶」PC的一次技术探索，基于智谱的多模态模型 CogAgent。目前开放第一阶段的内测场景，包括：\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"list\",\"tag\":\"ul\",\"children\":[{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"会议替身\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"：帮用户预定和参与会议，发送会议总结。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"文档处理\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"：支持文档下载、文档发送、理解和总结文档。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"网页搜索与总结\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"：在指定平台（如微信公众号、知乎、小红书等）搜索指定关键词，完成阅读、总结。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"远程和定时操作\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"：远程手机发指令，GLM-PC 可以自主完成电脑操作；设定一个未来时间，在开机状态下定时执行任务。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"隐形屏幕\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"：在用户工作时，GLM-PC 可以在隐形屏幕上自主完成工作，解放屏幕使用权。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"人用电脑的过程——\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"用眼看图形及文字，用脑规划，再用手执行单击双击、输入等操作。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"GLM-PC 用电脑的方式几乎完全和人一样。\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"也正因如此，理论上只要是为人类设计的应用，在GLM-PC学习之后它都能够执行。这是一种系统级、跨平台的能力，不依赖于 HTML、API，具备更高的能力上限。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"不过，由于 PC 的复杂程度，以及大家在 PC 完成的几乎都是复杂任务，坦率的说，今天大模型的能力距离真正代替大家办公还有一定距离。GLM-PC在当前版本下，用户仍需要输入非常精准的指令。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"GLM-PC「邀请体验」已开启。我们也会继续努力，在产品完善后尽快上线供所有用户使用，同时也希望和更多厂商联合共创共同探索。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"本次公测/内测的三个产品的落地页：\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"1.清言插件：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"https://new-front.chatglm.cn/webagent/landing/index.html?channel=ads_news_openday\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"2.autoglm-安卓：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"https://agent.aminer.cn/\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"3.glm-pc：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"https://www.wjx.top/vm/mOs9cHw.aspx\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"AutoGLM 和 GLM-PC 是我们迈向 AI 操作系统的重要尝试。它们的出现源于智谱在大语言模型、多模态模型、逻辑推理和工具使用等方面的技术积累。从23年4月的AgentBench开始，到8月的CogAgent模型，智谱针对AutoGLM、GLM-PC的模型CogAgent的研发工作已经进行了一年半的时间。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"与 OpenAI 有所不同，智谱定义了大模型发展的五个阶段：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"L1 语言能力、L2 逻辑能力（多模态能力）、L3 使用工具的能力、 L4 自我学习能力、 L5 探究科学规律。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"发展至今，大模型已经初步具备了人类与现实物理世界互动的部分能力。“Agent 将极大地提升 L3 使用工具能力，同时开启对 L4 自我学习能力的探索。” 张鹏说。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"289cfcaca0217caad9160f\",\"fields\":null,\"relationTo\":\"media\",\"value\":{\"id\":289,\"alt\":\"f85308a6-0b81-4c6a-a304-25e3bc4f29b7.png\",\"updatedAt\":\"2025-12-26T15:20:08.000Z\",\"createdAt\":\"2025-12-26T15:20:08.000Z\",\"url\":\"/api/media/file/django-summernote-2024-11-29-f85308a6-0b81-4c6a-a304-25e3bc4f29b7.png\",\"thumbnailURL\":null,\"filename\":\"django-summernote-2024-11-29-f85308a6-0b81-4c6a-a304-25e3bc4f29b7.png\",\"mimeType\":\"image/png\",\"filesize\":244550,\"width\":1280,\"height\":339,\"focalX\":null,\"focalY\":null}},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"张鹏表示，未来 GLM 团队将继续加速 agent 模型产品的研发，期待着一句话操作电脑和手机的范式尽快到来。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"大模型从 Chat 走向 Act\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"如今，大模型技术正\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"在改变机器和人的互动方式，基于理解需求、规划与决策、执行行动和自我反思，Agent 将带来符合直觉的人\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"机交互——\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"从人适应机器，到让机器适应人。\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"苹果（Apple Intelligence）、Anthr\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"opic（Computer Use）、谷歌（Jarvis）和 OpenAI（Operator）等企业也已经把 Agent 作为 2025 年的主要关注点。业内普遍认为，2025 年将是 Agent 爆发之年。Gartner 近期将 agentic AI 列为 2025 年十大技术趋势之一，并预测 2028 年至少有 15% 的日常工作决策将由 agentic AI 自主完成，而这一数字在 2024 年为 0。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"与 GenAI 不同，Agent 是目标驱动型的，能够完全执行工作流程，适应、学习、迭代、与其他系统和人类协作，并端到端地完成任务。在张鹏看来，Agent 可以看作是大模型通用操作系统 LLM-OS 的雏形。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"“现阶\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"段，AutoGLM 相当于在人与应用之间添加一个执行的调度层，很大程度上改变人机的交互形式。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"更重要的是，\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"我们看到了 LLM-OS 的可能，基于大模型智能能力（从 L1 到 L4 乃至更高）\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"，未来有机会实现原生的人机交互。将人机交互范式带向新的阶段。”\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"AI 时代智能设备新范式\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"随着大模型能力的不断进化，我们慢慢看到 AI 长出了自己的脑、眼和手，感知能力和交互带宽在不断丰富和拓展。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"智谱 COO 张帆表示，智能设备在大模型的加持下，将会焕发出新的机会。\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"手机+AI 会变成随身个人智能助理，PC+AI 将会成为全新生产力工具，汽车+AI 将会让车成为人们的智能第三生活空间。从手机、PC 和汽车，再推广到各类智能设备上，眼镜、家居和各种 edge side 设备，我们看到各种 AI 原生设备正在争相涌现。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"287cfcaca0217caad9160f\",\"fields\":null,\"relationTo\":\"media\",\"value\":{\"id\":287,\"alt\":\"a6726fea-3ab9-4a60-81f6-3d81769f443f.png\",\"updatedAt\":\"2025-12-26T15:20:08.000Z\",\"createdAt\":\"2025-12-26T15:20:08.000Z\",\"url\":\"/api/media/file/django-summernote-2024-11-29-a6726fea-3ab9-4a60-81f6-3d81769f443f.png\",\"thumbnailURL\":null,\"filename\":\"django-summernote-2024-11-29-a6726fea-3ab9-4a60-81f6-3d81769f443f.png\",\"mimeType\":\"image/png\",\"filesize\":215199,\"width\":1280,\"height\":340,\"focalX\":null,\"focalY\":null}},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"荣耀 AI 技术总监王作健、华硕 AIPC 智能生态负责人钟怀圣、小鹏汽车座舱智能语音/智能化业务负责人廉磊、高通 AI 产品技术中国区负责人万卫星、英特尔中国区技术部总经理高宇，\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"作为智谱的客户及合作伙伴，分别从不同的场景出发，分享了他们对智能终端的实践及展望。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"随着端侧性能及算力持续提升、为 AI 原生设\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"备适配的模型和端云同源的协同架构出现，更意味着大模型技术更广阔的落地空间。从智能设备走向智能网络，在不久的将来，我们将看到 AI 原生设备的互联互通和无限可能。在这个过程中，\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"智谱也将提供一系列的产品和能力，帮助智能设备们拥抱大模型，加速迈向 AI 原生设备新时代。\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1}},\"contentType_en\":\"content\",\"externalUrl_en\":null,\"content_en\":{\"root\":{\"type\":\"root\",\"children\":[{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"人类与机器的互动方式正在发生范式转变——这是由于只有对话功能的 Chatbot，正在进化为“有手、有脑、有眼睛”的自主 Agent。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"作为最早探索 Agent 的大模型企业之一，智谱今天带来了多个新进展：\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"list\",\"tag\":\"ul\",\"children\":[{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"AutoGLM 可以自主执行超过 50 步的长步骤操作，也可以跨 app 执行任务\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"AutoGLM开启「全自动」上网新体验，支持等数十个网站的无人驾驶\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"像人一样操作计算机的GLM-PC 启动内测，基于视觉多模态模型实现通用Agent的技术探索\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"在 OpenDay 现场，AutoGLM 给在场数百位嘉宾发送了\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"「AI给人类发的第一个红包」\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"，并且手机远程指挥电脑自动发送文件。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"而智谱 CEO 张鹏需要做的，只是在现场下达一个简单语音指令。这些原本对于机器而言非常复杂的操作，今天完全由智谱产品化的 Agent 完成。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"AutoGLM挑战更复杂\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"新升级的 AutoGLM 可以挑战完成复杂任务：\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"list\",\"tag\":\"ul\",\"children\":[{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"超长任务\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"：理解超长指令，执行超长任务。并且，在这种多步、循环任务中，AutoGLM 的速度表现超过人手动操作。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"跨App：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"AutoGLM 支持跨 App 来执行任务。由于目前 AutoGLM 形态更像是用户和应用间的APP执行的调度层，因此跨 App 能力是里面非常关键的一步。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"短口令：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"AutoGLM 能支持长任务的自定义短语。今天不用再给 AutoGLM 说：“帮我买一杯瑞幸咖啡，生椰拿铁，五道口店，大杯、热、微糖” ，只需要说“点咖啡”。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"随便模式：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"我们都会陷入选择恐惧，AutoGLM 今天可以主动帮你做出决策。随便模式下所有步骤都让 AI 决策，带来有抽盲盒式的惊喜。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"同时 AutoGLM 启动大规模百万内测，并将尽快上线成为面向 C 端用户的产品。AutoGLM 同时宣布启动\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"「10个亿级 APP 免费 Auto 升级」\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"的计划，邀请 App 伙伴联合探索自己的 Auto 新场景。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"支持核心场景和核心应用的 AutoGLM 标品 API，即将上线到智谱 maas 开放平台（bigmodel.cn）试用。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"Web 端开启「全自动」上网新体验\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"：智谱清言插件上线 AutoGLM 功能，支持搜索、微博、知乎、Github 等数十个网站的无人驾驶。在现场demo里，清言插件自动完成了“在百度搜索芒果tv，打开小巷人家，播放最新一集，发弹幕结局打卡”。全程没有人的干预。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"一次「无人驾驶」的\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"技术探索\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"不只是基于手机和浏览器，智谱还带来基于 PC 的自主Agent。GLM-PC 是 GLM 团队面向「无人驾驶」PC的一次技术探索，基于智谱的多模态模型 CogAgent。目前开放第一阶段的内测场景，包括：\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"list\",\"tag\":\"ul\",\"children\":[{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"会议替身\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"：帮用户预定和参与会议，发送会议总结。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"文档处理\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"：支持文档下载、文档发送、理解和总结文档。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"网页搜索与总结\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"：在指定平台（如微信公众号、知乎、小红书等）搜索指定关键词，完成阅读、总结。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"远程和定时操作\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"：远程手机发指令，GLM-PC 可以自主完成电脑操作；设定一个未来时间，在开机状态下定时执行任务。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"listitem\",\"children\":[{\"type\":\"text\",\"text\":\"隐形屏幕\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"：在用户工作时，GLM-PC 可以在隐形屏幕上自主完成工作，解放屏幕使用权。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"人用电脑的过程——\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"用眼看图形及文字，用脑规划，再用手执行单击双击、输入等操作。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"GLM-PC 用电脑的方式几乎完全和人一样。\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"也正因如此，理论上只要是为人类设计的应用，在GLM-PC学习之后它都能够执行。这是一种系统级、跨平台的能力，不依赖于 HTML、API，具备更高的能力上限。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"不过，由于 PC 的复杂程度，以及大家在 PC 完成的几乎都是复杂任务，坦率的说，今天大模型的能力距离真正代替大家办公还有一定距离。GLM-PC在当前版本下，用户仍需要输入非常精准的指令。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"GLM-PC「邀请体验」已开启。我们也会继续努力，在产品完善后尽快上线供所有用户使用，同时也希望和更多厂商联合共创共同探索。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"本次公测/内测的三个产品的落地页：\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"1.清言插件：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"https://new-front.chatglm.cn/webagent/landing/index.html?channel=ads_news_openday\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"2.autoglm-安卓：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"https://agent.aminer.cn/\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"3.glm-pc：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"https://www.wjx.top/vm/mOs9cHw.aspx\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"AutoGLM 和 GLM-PC 是我们迈向 AI 操作系统的重要尝试。它们的出现源于智谱在大语言模型、多模态模型、逻辑推理和工具使用等方面的技术积累。从23年4月的AgentBench开始，到8月的CogAgent模型，智谱针对AutoGLM、GLM-PC的模型CogAgent的研发工作已经进行了一年半的时间。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"与 OpenAI 有所不同，智谱定义了大模型发展的五个阶段：\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"L1 语言能力、L2 逻辑能力（多模态能力）、L3 使用工具的能力、 L4 自我学习能力、 L5 探究科学规律。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"发展至今，大模型已经初步具备了人类与现实物理世界互动的部分能力。“Agent 将极大地提升 L3 使用工具能力，同时开启对 L4 自我学习能力的探索。” 张鹏说。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"289cfcaca0217caad9160f\",\"fields\":null,\"relationTo\":\"media\",\"value\":\"$23:props:newsItems:4:content_zh:root:children:27:value\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"张鹏表示，未来 GLM 团队将继续加速 agent 模型产品的研发，期待着一句话操作电脑和手机的范式尽快到来。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"大模型从 Chat 走向 Act\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"如今，大模型技术正\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"在改变机器和人的互动方式，基于理解需求、规划与决策、执行行动和自我反思，Agent 将带来符合直觉的人\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"机交互——\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"从人适应机器，到让机器适应人。\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"苹果（Apple Intelligence）、Anthr\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"opic（Computer Use）、谷歌（Jarvis）和 OpenAI（Operator）等企业也已经把 Agent 作为 2025 年的主要关注点。业内普遍认为，2025 年将是 Agent 爆发之年。Gartner 近期将 agentic AI 列为 2025 年十大技术趋势之一，并预测 2028 年至少有 15% 的日常工作决策将由 agentic AI 自主完成，而这一数字在 2024 年为 0。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"与 GenAI 不同，Agent 是目标驱动型的，能够完全执行工作流程，适应、学习、迭代、与其他系统和人类协作，并端到端地完成任务。在张鹏看来，Agent 可以看作是大模型通用操作系统 LLM-OS 的雏形。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"“现阶\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"段，AutoGLM 相当于在人与应用之间添加一个执行的调度层，很大程度上改变人机的交互形式。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"更重要的是，\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"我们看到了 LLM-OS 的可能，基于大模型智能能力（从 L1 到 L4 乃至更高）\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"，未来有机会实现原生的人机交互。将人机交互范式带向新的阶段。”\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"AI 时代智能设备新范式\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"随着大模型能力的不断进化，我们慢慢看到 AI 长出了自己的脑、眼和手，感知能力和交互带宽在不断丰富和拓展。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"智谱 COO 张帆表示，智能设备在大模型的加持下，将会焕发出新的机会。\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"手机+AI 会变成随身个人智能助理，PC+AI 将会成为全新生产力工具，汽车+AI 将会让车成为人们的智能第三生活空间。从手机、PC 和汽车，再推广到各类智能设备上，眼镜、家居和各种 edge side 设备，我们看到各种 AI 原生设备正在争相涌现。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"287cfcaca0217caad9160f\",\"fields\":null,\"relationTo\":\"media\",\"value\":\"$23:props:newsItems:4:content_zh:root:children:37:value\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"荣耀 AI 技术总监王作健、华硕 AIPC 智能生态负责人钟怀圣、小鹏汽车座舱智能语音/智能化业务负责人廉磊、高通 AI 产品技术中国区负责人万卫星、英特尔中国区技术部总经理高宇，\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"作为智谱的客户及合作伙伴，分别从不同的场景出发，分享了他们对智能终端的实践及展望。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"随着端侧性能及算力持续提升、为 AI 原生设\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"备适配的模型和端云同源的协同架构出现，更意味着大模型技术更广阔的落地空间。从智能设备走向智能网络，在不久的将来，我们将看到 AI 原生设备的互联互通和无限可能。在这个过程中，\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"智谱也将提供一系列的产品和能力，帮助智能设备们拥抱大模型，加速迈向 AI 原生设备新时代。\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1}},\"featured\":true,\"thumbnail_zh\":\"/api/media/file/%E6%96%B0%E9%97%BB%E7%A8%BF_AGENT_3_GyorD1O.png\",\"thumbnail_en\":\"/api/media/file/%E6%96%B0%E9%97%BB%E7%A8%BF_AGENT_3_GyorD1O.png\",\"active\":true,\"order\":0,\"tag_zh\":[\"技术前沿\"],\"tag_en\":[],\"apiConfig_zh\":null,\"apiConfig_en\":null,\"experienceUrl_zh\":null,\"experienceUrl_en\":null,\"updatedAt\":\"2026-01-07T11:45:18.893Z\",\"createdAt\":\"2024-11-28T07:38:03.621Z\"},{\"id\":20,\"title_zh\":\"智谱与英特尔深化智能生态合作，落地端侧智谱清言和CodeGeeX智能编程助手\",\"title_en\":null,\"createAt\":\"2024-11-07T09:22:12.871Z\",\"category\":\"news\",\"resume_zh\":\"10月25日，英特尔 AI PC 生态大会暨英特尔酷睿Ultra处理器（第二代）品鉴会上，智谱作为英特尔的重要合作伙伴受邀出席，分享了智谱和英特尔在AI PC领域联合共创的最新成果：端侧智谱清言和 CodeGeeX 智能编程助手 AIPC 版，携手赋能 AIPC 领域的智能“芯”动力。基于端云一体的模型产品矩阵，智谱和英特尔共同落地多款 AI PC 应用创新成果。智谱副总裁吴玮杰在大会上介绍了端侧\",\"resume_en\":\"10月25日，英特尔 AI PC 生态大会暨英特尔酷睿Ultra处理器（第二代）品鉴会上，智谱作为英特尔的重要合作伙伴受邀出席，分享了智谱和英特尔在AI PC领域联合共创的最新成果：端侧智谱清言和 CodeGeeX 智能编程助手 AIPC 版，携手赋能 AIPC 领域的智能“芯”动力。基于端云一体的模型产品矩阵，智谱和英特尔共同落地多款 AI PC 应用创新成果。智谱副总裁吴玮杰在大会上介绍了端侧\",\"contentType_zh\":\"content\",\"externalUrl_zh\":null,\"content_zh\":{\"root\":{\"type\":\"root\",\"children\":[{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"10月25日，英特尔 AI PC 生态大会暨英特尔酷睿Ultra处理器（第二代）品鉴会上，智谱作为英特尔的重要合作伙伴受邀出席，分享了智谱和英特尔在AI PC领域联合共创的最新成果：\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"端侧智谱清言和 CodeGeeX 智能编程助手 AIPC 版，携手赋能 AIPC 领域的智能“芯”动力。\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"791cfcaca0217caad9160f\",\"fields\":null,\"relationTo\":\"media\",\"value\":{\"id\":791,\"alt\":\"0888129f-561e-480a-b93b-34160b6571ee.png\",\"updatedAt\":\"2025-12-26T15:20:08.000Z\",\"createdAt\":\"2025-12-26T15:20:08.000Z\",\"url\":\"/api/media/file/django-summernote-2024-11-07-0888129f-561e-480a-b93b-34160b6571ee.png\",\"thumbnailURL\":null,\"filename\":\"django-summernote-2024-11-07-0888129f-561e-480a-b93b-34160b6571ee.png\",\"mimeType\":\"image/png\",\"filesize\":881108,\"width\":1080,\"height\":720,\"focalX\":null,\"focalY\":null}},{\"type\":\"text\",\"text\":\"基于端云一体的模型产品矩阵，智谱和英特尔共同落地多款 AI PC 应用创新成果。智谱副总裁吴玮杰在大会上介绍了端侧智谱清言、CodeGeeX 智能编程助手 AIPC 版等两款与英特尔联合打造的 AI PC 产品，并通过现场真机演示，展示产品的具体应用场景与潜力。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"01端侧智谱清言\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"基于英特尔酷睿 Ultra 芯片优化，联网使用的智谱清言已具备离线运行能力，双方联合打造的端侧智谱清言能够为用户提供高速推理的AI体验。\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"离线状态下，端侧智谱清言仍能轻松应对AI对话、处理长文档分析等复杂任务。提供本地处理“隐私模式”选择，保障用户数据和个人文档等信息数据安全。结合云端的强大能力，端侧智谱清言支持解锁智能体搭建、AI识图画图、高效AI搜索等能力，为工作和生活带来前所未有的便捷，一“言”即达，提升工作效率，让创意无限放大。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"790cfcaca0217caad9160f\",\"fields\":null,\"relationTo\":\"media\",\"value\":{\"id\":790,\"alt\":\"44c5aec1-f6ef-4bc4-a0e9-fc1c8a0dd1b9.png\",\"updatedAt\":\"2025-12-26T15:20:08.000Z\",\"createdAt\":\"2025-12-26T15:20:08.000Z\",\"url\":\"/api/media/file/django-summernote-2024-11-07-44c5aec1-f6ef-4bc4-a0e9-fc1c8a0dd1b9.png\",\"thumbnailURL\":null,\"filename\":\"django-summernote-2024-11-07-44c5aec1-f6ef-4bc4-a0e9-fc1c8a0dd1b9.png\",\"mimeType\":\"image/png\",\"filesize\":824997,\"width\":1080,\"height\":720,\"focalX\":null,\"focalY\":null}},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"02\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"CodeGeeX智能编程助手AIPC版\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"依托酷睿 Ultra 处理器先进的制程工艺和集成的高性能内核，CodeGeeX 智能编程助手 AIPC 版能够以低功耗和高性能完成AI任务。\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"支持多种主流编程语言和IDE，如Python、Java、C++/C、JavaScript等，且与VS Code、IntelliJ IDEA、PyCharm等主流IDE兼容。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"在HumanEval-X任务上，CodeGeeX的高精度代码生成和跨语言代码翻译功能优于其他基线模型。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"AIPC搭载CodeGeeX智能编程助手，为有编程需求群体提供代码自动生成和补全、代码翻译、智能问答、项目级代码解释以及项目地图等功能，显著提高编程效率\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"63cfcaca0217caad9160f\",\"fields\":null,\"relationTo\":\"media\",\"value\":{\"id\":63,\"alt\":\"4.png\",\"updatedAt\":\"2025-12-26T15:20:08.000Z\",\"createdAt\":\"2025-12-26T15:20:08.000Z\",\"url\":\"/api/media/file/4.png\",\"thumbnailURL\":null,\"filename\":\"4.png\",\"mimeType\":\"image/png\",\"filesize\":482203,\"width\":718,\"height\":380,\"focalX\":null,\"focalY\":null}},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"此外，本次英特尔AI PC生态大会对智谱与机械革命将联合推出一款面向程序开发人群设计的笔记本产品进行特别预告，该产品预计于11月底正式与大家见面。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"伴随着AI应用普及化趋势日益显著，智能终端需求旺盛。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"智谱与英特尔携手，将充分发挥双方优势，共同推动AI PC应用在端侧的落地\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"，推动人机交互范式实现新转变。\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1}},\"contentType_en\":\"content\",\"externalUrl_en\":null,\"content_en\":{\"root\":{\"type\":\"root\",\"children\":[{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"10月25日，英特尔 AI PC 生态大会暨英特尔酷睿Ultra处理器（第二代）品鉴会上，智谱作为英特尔的重要合作伙伴受邀出席，分享了智谱和英特尔在AI PC领域联合共创的最新成果：\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"端侧智谱清言和 CodeGeeX 智能编程助手 AIPC 版，携手赋能 AIPC 领域的智能“芯”动力。\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"791cfcaca0217caad9160f\",\"fields\":null,\"relationTo\":\"media\",\"value\":\"$23:props:newsItems:5:content_zh:root:children:0:children:2:value\"},{\"type\":\"text\",\"text\":\"基于端云一体的模型产品矩阵，智谱和英特尔共同落地多款 AI PC 应用创新成果。智谱副总裁吴玮杰在大会上介绍了端侧智谱清言、CodeGeeX 智能编程助手 AIPC 版等两款与英特尔联合打造的 AI PC 产品，并通过现场真机演示，展示产品的具体应用场景与潜力。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"01端侧智谱清言\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"基于英特尔酷睿 Ultra 芯片优化，联网使用的智谱清言已具备离线运行能力，双方联合打造的端侧智谱清言能够为用户提供高速推理的AI体验。\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"离线状态下，端侧智谱清言仍能轻松应对AI对话、处理长文档分析等复杂任务。提供本地处理“隐私模式”选择，保障用户数据和个人文档等信息数据安全。结合云端的强大能力，端侧智谱清言支持解锁智能体搭建、AI识图画图、高效AI搜索等能力，为工作和生活带来前所未有的便捷，一“言”即达，提升工作效率，让创意无限放大。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"790cfcaca0217caad9160f\",\"fields\":null,\"relationTo\":\"media\",\"value\":\"$23:props:newsItems:5:content_zh:root:children:1:value\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"02\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"CodeGeeX智能编程助手AIPC版\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"依托酷睿 Ultra 处理器先进的制程工艺和集成的高性能内核，CodeGeeX 智能编程助手 AIPC 版能够以低功耗和高性能完成AI任务。\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"支持多种主流编程语言和IDE，如Python、Java、C++/C、JavaScript等，且与VS Code、IntelliJ IDEA、PyCharm等主流IDE兼容。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"在HumanEval-X任务上，CodeGeeX的高精度代码生成和跨语言代码翻译功能优于其他基线模型。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"AIPC搭载CodeGeeX智能编程助手，为有编程需求群体提供代码自动生成和补全、代码翻译、智能问答、项目级代码解释以及项目地图等功能，显著提高编程效率\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"63cfcaca0217caad9160f\",\"fields\":null,\"relationTo\":\"media\",\"value\":\"$23:props:newsItems:5:content_zh:root:children:8:value\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"此外，本次英特尔AI PC生态大会对智谱与机械革命将联合推出一款面向程序开发人群设计的笔记本产品进行特别预告，该产品预计于11月底正式与大家见面。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"paragraph\",\"tag\":null,\"children\":[{\"type\":\"text\",\"text\":\"伴随着AI应用普及化趋势日益显著，智能终端需求旺盛。\",\"format\":0,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"智谱与英特尔携手，将充分发挥双方优势，共同推动AI PC应用在端侧的落地\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1},{\"type\":\"text\",\"text\":\"，推动人机交互范式实现新转变。\",\"format\":1,\"detail\":0,\"mode\":\"normal\",\"style\":\"\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1,\"textFormat\":0,\"textStyle\":\"\"}],\"direction\":null,\"format\":\"\",\"indent\":0,\"version\":1}},\"featured\":true,\"thumbnail_zh\":\"/api/media/file/%E5%9B%BE%E7%89%872.png\",\"thumbnail_en\":\"/api/media/file/%E5%9B%BE%E7%89%872.png\",\"active\":true,\"order\":0,\"tag_zh\":[\"业务\"],\"tag_en\":[],\"apiConfig_zh\":null,\"apiConfig_en\":null,\"experienceUrl_zh\":null,\"experienceUrl_en\":null,\"updatedAt\":\"2026-01-07T11:45:18.806Z\",\"createdAt\