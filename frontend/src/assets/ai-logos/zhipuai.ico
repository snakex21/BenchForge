ined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}],{\"children\":[[\"$\",\"$1\",\"c\",{\"children\":[[[\"$\",\"link\",\"0\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/css/739d117be2f6ea06.css\",\"precedence\":\"next\",\"crossOrigin\":\"$undefined\",\"nonce\":\"$undefined\"}]],\"$L5\"]}],{\"children\":[[\"$\",\"$1\",\"c\",{\"children\":[\"$L6\",null,[\"$\",\"$L7\",null,{\"children\":[\"$\",\"$8\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@9\"}]}]]}],{},null,false,false]},null,false,false]},null,false,false]},null,false,false],[\"$\",\"$1\",\"h\",{\"children\":[null,[\"$\",\"$La\",null,{\"children\":\"$@b\"}],[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$Lc\",null,{\"children\":[\"$\",\"$8\",null,{\"name\":\"Next.Metadata\",\"children\":\"$@d\"}]}]}],null]}],false]],\"m\":\"$undefined\",\"G\":[\"$e\",[]],\"S\":false}\n"])</script><script>self.__next_f.push([1,"b:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\nd:[[\"$\",\"title\",\"0\",{\"children\":\"Z.ai - Inspiring AGI to Benefit Humanity\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"智谱推出 AutoClaw（澳龙）——国内首款一键安装的本地 OpenClaw 客户端。内置50+Skills，集成 AutoGLM 浏览器操作能力，下载地址：https://autoglm.zhipuai.cn/autoclaw\"}],[\"$\",\"meta\",\"2\",{\"name\":\"keywords\",\"content\":\"z.ai, 智谱AI, 智谱清言, zhipuai, 智谱官网, GLM, GLM-5, GLM-4.7, GLM-4.6V, GLM-4.5V, AutoClaw, 澳龙, AutoGLM, CogAgent, AI平台, 免费AI助手, AI API, LLM API, 大模型API, 开发者AI工具, 多模态AI, 视觉语言模型, VLM, AI编程助手, GLM Coding Plan, 代码补全AI, AI代码生成, AI图像生成, AI视频生成, AI PPT, AI文档分析, AI OCR, 模型微调, AI搜索, 企业AI解决方案, 企业大模型, 程序员AI工具, 开源大模型, AGI, Zread.ai, AMiner\"}],[\"$\",\"link\",\"3\",{\"rel\":\"icon\",\"href\":\"/favicon.png\"}],[\"$\",\"$Lf\",\"4\",{}]]\n9:null\n5:[\"$\",\"html\",null,{\"lang\":\"favicon.ico\",\"children\":[\"$\",\"body\",null,{\"className\":\"flex min-h-screen flex-col overflow-y-scroll antialiased en-win-font\",\"children\":\"$L10\"}]}]\n"])</script><script>self.__next_f.push([1,"4:[\"$\",\"$L11\",null,{\"formats\":\"$undefined\",\"locale\":\"zh\",\"messages\":{\"about\":\"关于我们\",\"about_title\":\"关于智谱\",\"about_zhipu_desc\":\"智谱（Z.AI）成立于2019年，由清华大学技术成果转化而来。公司以“让机器像人一样思考”为愿景，始终专注通用人工智能（AGI）的研发。团队率先启动国内大模型的研究工作，研发出基于自回归填空的全国产预训练架构GLM，在鲁棒性、可控性和幻觉性方面取得出众效果，模型适配了40余款国产芯片。\u003cbr/\u003e\u003cbr/\u003e2025年，智谱（Z.AI）推出新一代旗舰模型GLM-4.5/4.6，首次实现在一个模型中原生融合推理、编码和智能体能力，模型立即在12项权威评测中综合排名取得国内第一、全球开源第一的效果。尤其是模型的Coding能力取得关键突破，在全球公认百万用户盲测的大模型竞技场Code Arena上，GLM与Anthropic、OpenAI的模型并列Coding全球第一，超越海外闭源模型谷歌Gemini和xai的Grok，第一次有中国模型实现该名次。在全球大模型超市OpenRouter（体现全球大模型真实调用量）上，GLM-4.5/4.6自上线以来调用量稳居全球前10，同时付费API收入超过所有国产模型之和。\u003cbr/\u003e\u003cbr/\u003e智谱连续三年实现收入翻倍增长，已经发展成为中国大型的独立大模型厂商。目前，GLM系列大模型应用于民生治理、工业制造、能源电力、金融、互联网、通信、消费电子、教育等行业，拥有超过270万的客户与开发者。\",\"about_zhipu_title\":\"北京智谱华章科技股份有限公司\",\"about_hero_title\":\"让机器像人一样思考\",\"about_hero_desc\":\"Teach machines to think like humans\",\"address\":\"北京市海淀区中关村东路 1 号院 9 号楼 10 层\",\"ai_slides\":\"AI Slides\",\"maasSection\":{\"description\":\"我们不止生产模型  更构建可信智能\",\"description1\":\"提供能力全球领先、灵活易用、高性价比的全模态大模型 API 服务\",\"description2\":\"数十个深度耦合业务的应用级 API，开箱即用，直击千行百业真需求\",\"description3\":\"一站式、组件化大模型开发，享受高效定制模型体验，保障企业级 AI 应用落地\",\"items1\":{\"desc1\":\"智谱面向智能体工程推出的全新旗舰基座模型，在编码和智能体能力方面实现了开源SOTA性能\",\"desc2\":\"视觉理解精度达同规模 SOTA，原生支持工具调用，能自动完成任务，支持 128K 长上下文\"},\"items2\":{\"desc1\":\"精通多国语种，精确识别语境、语体、俚语及专业术语，实现高保真情景化翻译\",\"desc2\":\"从搜索到设计，一键生成精美可用的PPT/海报, 文字图表智能完美融合\",\"title1\":\"通用翻译\",\"title2\":\"GLM PPT/海报\"},\"items3\":{\"desc1\":\"支持对语言、多模态模型的多种微调方案，低至十分钟完成微调，让模型更懂你的任务场景\",\"desc2\":\"集成多家搜索引擎，专为大模型优化，助力 AI 应用生成实时、精准、可溯源的内容\",\"title1\":\"模型微调\",\"title2\":\"AI 搜索工具\"},\"title1\":\"高效能模型服务\",\"title2\":\"精选智能体应用\",\"title3\":\"全流程开发套件\",\"viewAll\":\"查看全部\"},\"autoglm\":{\"desc\":\"自主规划并执行复杂多步骤任务的智能体模型\"},\"banner_button\":\"立刻了解\",\"banner_text\":\"GLM Coding Plan 编码套餐：低至20元包月，畅享全球顶级编码体验\",\"businessEcosystem\":{\"description\":\"帮助行业合作伙伴与各城市做出成功的大模型应用\",\"title\":\"商业生态\"},\"business_cooperation\":\"商务合作\",\"marketing\":\"市场公关\",\"investors_relations\":\"投资者关系\",\"business_license\":\"营业执照\",\"chat_placeholder\":\"今天有什么可以帮助你？\",\"chatglm_6b\":{\"desc\":\"中国第一个对话模型\"},\"contact_business_type\":\"※ 您咨询的业务类型\",\"contact_button_text\":\"合作咨询\",\"contact_code\":\"※ 请输入验证码\",\"contact_company\":\"※ 您的公司名称\",\"contact_description\":\"我们最新的前沿模型系列，在推理、编码和智能体任务方面表现出色\",\"contact_name\":\"※ 请输入您的姓名\",\"contact_phone\":\"※ 请输入您的电话\",\"contact_select_digital_human\":\"数字人\",\"contact_select_llm\":\"大模型\",\"contact_select_news_media\":\"新闻媒体\",\"contact_select_other\":\"其它\",\"contact_submit\":\"预约咨询\",\"contact_submit_error\":\"网络异常，表单提交失败，请检查网络后重试\",\"contact_submit_error_desc\":\"请稍后再试\",\"contact_submit_success\":\"提交成功\",\"contact_submit_success_desc\":\"我们会尽快与您联系\",\"contact_submitting\":\"提交中...\",\"contact_title\":\"业务咨询\",\"copyright\":\"Copyright ◎ 2025-2026 北京智谱华章科技股份有限公司\",\"ending\":{\"button\":\"免费试用\",\"description\":\"注册立享 2000万 tokens\",\"title\":\"日均付费调用量超万亿tokens  累计服务超270万开发者，日活超20万开发者\",\"title1\":\"中国大型独立大模型厂商,\",\"title2\":\"国产原创GLM大模型架构，编程能力并列全球第一\",\"title_mobile1\":\"中国大型独立大模型厂商\",\"title_mobile2\":\"国产原创GLM大模型架构\",\"title_mobile3\":\"编程能力并列全球第一\"},\"full_stack\":\"Full Stack\",\"glmSection\":{\"glm_5\":{\"title\":\"GLM-5\",\"desc\":\"在 SWE-bench Verified、Terminal Bench 2.0 等智能体编程核心榜单上，GLM-5 达到开源模型 SOTA，比肩 Claude Opus 4.5\"},\"glm_5_t\":{\"title\":\"GLM-5-Turbo\",\"desc\":\"专为龙虾场景打造的基座模型\"},\"glm_4_6V\":{\"title\":\"GLM-4.6V\",\"desc\":\"全球 100B 级效果表现出众的开源视觉推理模型，并同步开源\"},\"autoGLM\":{\"title\":\"AutoGLM\",\"desc\":\"具备自主规划、推理与执行能力的智能体模型，解决了任务规划、数据稀缺和策略优化等核心难题，具备持续自我改进能力\"},\"cogView4\":{\"title\":\"CogView4\",\"desc\":\"擅长理解和遵循中文提示词，能够在画面中生成汉字的开源文生图模型\"},\"glm_Z1_Rumination\":{\"title\":\"GLM-Z1-沉思\",\"desc\":\"能自主执行“实时搜索、深度分析、自我验证”全流程，以完成复杂研究任务的智能体。\"},\"featureDescription\":\"专为龙虾场景打造的基座模型，从训练层深度优化Agent核心能力，大幅提升工具调用与长链路执行能力。\",\"featureTitle\":\"GLM-5-Turbo\",\"subtitle\":\"新一代大模型全栈技术体系\",\"title\":\"GLM模型\"},\"glm_130b\":{\"desc\":\"中国第一个开源千亿模型\"},\"glm_4_6v\":{\"desc\":\"全球 100B 级效果表现出众的开源视觉推理模型\"},\"glm_5\":{\"desc\":\"GLM-5 达到开源模型 SOTA，比肩 Claude Opus 4.5\"},\"glm_5_t\":{\"desc\":\"专为龙虾场景打造的基座模型\"},\"glm_image\":{\"desc\":\"智谱联合华为开源首个国产芯片训练的多模态 SOTA 模型\"},\"hello_world\":\"你好世界\",\"help_me_write\":\"Help Me Write\",\"introduction_desc\":\"自主创新的算法、领先的中文认知大模型企业\",\"introduction_title\":\"公司简介\",\"issue_description\":\"请描述您想要咨询的问题\",\"join_us_desc\":\"一群正直的、有激情的年轻人，聚在一起，做创新的、对社会有价值的事\",\"join_us_title\":\"加入我们\",\"joinus\":{\"benefits\":{\"annual_leave\":{\"description\":\"平衡工作，享受生活，让我们在忙碌中也能拥抱悠闲时光，为身心充电\",\"title\":\"丰厚的年假\"},\"flexible_hours\":{\"description\":\"自由工作，高效非凡，员工可根据自身情况灵活安排，轻松应对繁忙工作，提升工作幸福感\",\"title\":\"弹性办工时间\"},\"team_building\":{\"description\":\"欢乐时光，凝聚力量，大家在轻松氛围中交流分享，增进感情，携手共进\",\"title\":\"下午茶团建\"},\"title\":\"智谱福利\"},\"hero\":{\"campus_recruitment\":\"校园招聘\",\"social_recruitment\":\"社会招聘\",\"subtitle\":\"一群正直的、有激情的年轻人，聚在一起，做创新的、对社会有价值的事\",\"title\":\"Think Big ，Deliver Solid ，Scale Stable\"},\"job_categories\":{\"algorithm_campus\":\"算法（校招）\",\"algorithm_campus_description\":\"持续改进训练框架和策略，提升模型训练效率等\",\"campus_recruitment_cta\":\"校园招聘\",\"functional_campus\":\"运营（校招）\",\"functional_campus_description\":\"结合大模型技术优势，参与设计创新的AI解决方案\",\"job_description\":\"负责大模型相关算法的研究与开发\",\"product\":\"产品经理/项目经理（社招）\",\"product_description\":\"项目计划、风险管理、质量管理等\",\"research\":\"算法/研发（社招）\",\"research_campus\":\"研发 (校招)\",\"research_campus_description\":\"强化学习训练框架的研发、优化和维护等\",\"research_description\":\"持续改进训练框架和策略，提升模型训练效率等\",\"sales\":\"销售（社招）\",\"sales_description\":\"大模型相关产品及应用在各个领域的开拓及销售\",\"social_recruitment_cta\":\"社会招聘\",\"title\":\"职位类别\"},\"locations\":{\"beijing\":\"北京\",\"chengdu\":\"成都\",\"hangzhou\":\"杭州\",\"kuala_lumpur\":\"吉隆坡\",\"shanghai\":\"上海\",\"shenzhen\":\"深圳\",\"title\":\"工作地点\"}},\"investor_relations\":\"投资者关系\",\"investor_relations_desc\":\"致力于准确、全面的信息披露，树立开放、透明的企业形象\",\"license\":\"许可证\",\"link_text\":\"了解更多\",\"magic_design\":\"Magic Design\",\"nav_product_aminer_desc\":\"聚焦科研检索、阅读、分析、写作场景的 AI 助手\",\"nav_product_autoglm_desc\":\"全球首个手机Agent，一句话实现「云端操作+自动执行」\",\"nav_product_chatglm_desc\":\"GLM大模型全能助手\",\"nav_product_zread_desc\":\"让代码的价值，被更高效地挖掘与传递\",\"nav_product_dongdongzoo_desc\":\"为你而来的 AI 生命，全球首个多模态娱乐社交产品\",\"nav_product_zai_desc\":\"全能 AI 助手，轻松搞定编程、写作与演示文稿\",\"nav_product_autotyper_desc\":\"智能AI语音输入助手，让语音比打字快4倍！\",\"news_desc\":\"了解更多智谱的资讯动态\",\"news_page\":{\"button_platform\":\"开放平台\",\"button_try\":\"立即体验\",\"load_more_button\":\"没有更多...\",\"subtitle\":\"结合科研能力和转化创新力量，助力拓展科技前沿，以应对社会尚未解决的需求\",\"title\":\"新闻和资讯\"},\"news_page_load_more_button\":\"查看更多\",\"news_page_loading\":\"加载中...\",\"news_section\":{\"title\":\"最新动态\"},\"news_title\":\"新闻动态\",\"product\":\"产品\",\"product_aminer_desc\":\"面向全球用户提供最新的GLM模型免费在线体验，为用户提供高效便捷的编程、写作与演示文稿功能\",\"product_auto_glm_desc\":\"AI 不止对话，触控执行解放双手。AutoGLM 是一款Agent 智能体产品，它能通过远程操作云设备，自动完成移动端 App 操作、跨 APP 交互及网页任务执行等操作，可以帮助用户更智慧便捷完成各种任务\",\"product_chatglm_title\":\"智谱清言\",\"product_autotyper_title\":\"智谱AI输入法\",\"product_zlearn_title\":\"智谱学习中心\",\"product_zread_desc\":\"让代码的价值，被更高效地挖掘与传递\",\"product_dongdongzoo_desc\":\"全球首个多模态娱乐社交产品，融合了人工智能、图像识别与情感化交互技术，开创“拍照即生命”的全新互动体验。在这里，每一次点击快门，都可能唤醒一个独一无二的AI生命\",\"product_dongdongzoo_title\":\"动动动物圈\",\"product_section\":{\"subtitle\":\"用可信赖 AI 让生活更美好\",\"title\":\"原生产品\"},\"product_zai_desc\":\"面向全球用户提供最新的GLM模型免费在线体验，为用户提供高效便捷的编程、写作与演示文稿功能\",\"product_zhipu_qingyan_desc\":\"快、准、能思考的AI效率工具。用户量超3000万，活跃智能体80万个。搭载最新的GLM大模型，响应更快、思考更深，联合海淀名师打造行业领先的 AI 学习助手\",\"product_autoclaw_title\":\"AutoClaw\",\"product_autoclaw_desc\":\"只需1分钟，给每台电脑装上小龙虾\",\"search_info\":\"Search info\",\"site_title\":\"智谱AI\",\"speech_recognition_not_supported\":\"您的浏览器不支持语音识别功能\",\"speech_recognition_not_supported_desc\":\"请使用 Chrome、Edge 或其他支持 Web Speech API 的浏览器\",\"timeline_2019_03\":\"智谱成立， 源自清华计算机系知识工程实验室 (KEG) \",\"timeline_2021_03\":\"发布自研预训练框架 GLM, 打破BERT/GPT 瓶颈\",\"timeline_2022_09\":\"中国第一个开源的千亿基座模型GLM-130B \",\"timeline_2023_03\":\"中国第一个千亿对话基座模型ChatGLM\",\"timeline_2024_01\":\"发布新一代基座大模型 GLM-4，国内率先对标GPT4\",\"timeline_2024_08\":\"中国第一个对齐文本/图像/视频/声音的多模型模型VideoCall\",\"timeline_2024_10\":\"发布全球首个手机智能体AutoGLM\",\"timeline_2024_12\":\"发布并上线推理模型GLM-Zero Preview\",\"timeline_2025_03\":\"发布沉思模型, 首次集合操作能力AutoGLM沉思\",\"timeline_2025_07\":\"发布面向推理、代码与智能体的开源SOTA模型 GLM-4.5\",\"timeline_2025_10\":\"智谱最新旗舰 GLM-4.6，代码能力全面对齐 Claude Sonnet 4，更好支持复杂长线任务，综合能力达全球开源模型 SOTA\",\"timeline_2025_12\":\"智谱发布新一代旗舰模型 GLM-4.7，国内最好的 Coding 模型，LM Arena 开源第一、全球第四，全球⼤模型API超市 OpenRouter 趋势榜第一\",\"timeline_title\":\"发展历程\",\"detail_text\":\"详情\",\"nav_api\":{\"bigmodel\":{\"title\":\"Bigmodel\",\"description\":\"智谱GLM大模型应用平台，五百强企业和百万开发者都在用\"}},\"chat_section\":{\"brainstorming\":\"头脑风暴\",\"brainstorming_template\":[{\"description\":\"帮我想出3个具有创意性的联名款产品营销策略，和2个有趣的线上挑战用于社媒营销\"},{\"description\":\"安排一下新疆10天旅行计划\"},{\"description\":\"我想写一篇研究大模型的文章，请给我提供几个写作角度和研究方法\"}],\"logical_reasoning\":\"逻辑推理\",\"logical_reasoning_template\":[{\"description\":\"如果某个城市的平均气温较高，它的空气污染会怎样变化？\"},{\"description\":\"当股票市场上涨时，消费者的消费倾向通常会怎样变化？为什么？\"},{\"description\":\"判断以下命题的真假：若所有的苹果都是水果，某个物品是水果，则它一定是苹果\"}],\"information_qa\":\"信息问答\",\"information_qa_template\":[{\"description\":\"请解释一下鲶鱼效应和霍桑效应分别是什么\"},{\"description\":\"我的宠物是一只小狗，他的饮食上需要注意哪些地方？\"},{\"description\":\"请告诉我第30届《联合国气候变化框架公约》缔约方会议（COP 30）的核心议题\"}],\"content_creation\":\"内容创作\",\"content_creation_template\":[{\"description\":\"创作一个独特的短视频剧本，并设计它的主要情节和整体风格\"},{\"description\":\"请你帮我写一封线下活动的邀请邮件，并再写一段有活人感的宣传文案，用于小红书的宣发\"},{\"description\":\"给我一个关于如何提高产品广告吸引力的创意文案\"}],\"creative_development\":\"创意开发\",\"creative_development_template\":[{\"description\":\"构建一个高端家具品牌的HTML网站，要求UI风格为深棕色+高级质感+故事感\"},{\"description\":\"制作一个带有奶油色背景和深灰色衬线标题的个人博客，引用块使用手写字体，极简侧边栏导航\"},{\"description\":\"请帮我制作公司网页，公司致力于为企业提供各种数字化解决方案，风格高级，磁吸导航且项目卡片3D倾斜\"}]},\"contact_error_name\":\"请输入您的姓名\",\"contact_error_mobile\":\"请输入您的手机号\",\"contact_error_company\":\"请输入公司名称\",\"contact_error_business\":\"请选择业务类型\",\"contact_error_invalid_mobile\":\"请输入有效的手机号码\",\"contact_qrcode_title\":\"提交成功! 🎉\",\"contact_qrcode_description\":\"您已提交，我们会尽快与您联系，邀请您添加企微客服，以便向您同步最新进展\",\"contact_qrcode_tip\":\"扫一扫添加智谱企微客服\",\"go_back\":\"返回首页\",\"back_button\":\"返回\",\"research\":{\"title\":\"研究\",\"description\":\"关于 GLM 大模型家族\",\"tag\":{\"all\":\"全部\",\"base_model\":\"基座模型\",\"mutimodal_model\":\"多模态\",\"reasoning_model\":\"推理模型\",\"agent_model\":\"Agent\",\"code_model\":\"代码模型\"},\"time_sort\":\"时间排序\",\"load_more\":\"加载更多\"},\"article\":{\"try_now\":\"立即体验\",\"get_api\":\"获取API\"}},\"now\":\"$undefined\",\"timeZone\":\"UTC\",\"children\":\"$L12\"}]\n"])</script><script>self.__next_f.push([1,"10:[\"$\",\"$L11\",null,{\"formats\":\"$undefined\",\"locale\":\"zh\",\"messages\":\"$4:props:messages\",\"now\":\"$undefined\",\"timeZone\":\"UTC\",\"children\":[\"$\",\"$L13\",null,{\"isMobile\":false,\"children\":[\"$\",\"$L14\",null,{\"navConfig\":[{\"id\":4,\"article\":{\"id\":156,\"title_zh\":\"GLM-5V-Turbo发布：多模态Coding基座模型\",\"title_en\":\"GLM-5V-Turbo: A Multimodal Coding Foundation Model\",\"createAt\":\"2026-04-01T16:00:00.000Z\",\"category\":\"blog\",\"resume_zh\":null,\"resume_en\":\"A multimodal coding foundation model for visual programming\",\"contentType_zh\":\"content\",\"externalUrl_zh\":null,\"content_zh\":{\"root\":{\"children\":[{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"Agent时代，模型能力由模型智能以及其处理的context容量两个维度定义。一个能够原生处理图片、视频、文本等多模态context，同时擅长复杂编程、长程规划、动作执行的Coding基座模型，将是所有AI原生应用的基石。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"今天，我们发布\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"GLM-5V-Turbo\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"，面向视觉编程打造的多模态Coding基座模型。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"GLM-5V-Turbo从预训练阶段深度融合视觉与文本能力，让编程不再局限于纯文本输入。模型能看懂设计稿、截图、网页界面，并据此生成完整可运行的代码，真正做到看得懂画面、写得出代码。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"69cf9751f21c2c2005c82ca7\",\"fields\":null,\"relationTo\":\"media\",\"value\":{\"id\":955,\"alt\":\" \",\"updatedAt\":\"2026-04-03T10:32:49.527Z\",\"createdAt\":\"2026-04-03T10:32:49.526Z\",\"url\":\"/api/media/file/%E6%99%BA%E8%B0%B1-%E4%B8%BBCase-%E4%B8%AD%E6%96%87-0402%20(1).m4v\",\"thumbnailURL\":null,\"filename\":\"智谱-主Case-中文-0402 (1).m4v\",\"mimeType\":\"video/mp4\",\"filesize\":159012884,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null}},{\"children\":[],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"核心要点如下：\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"原生多模态Coding基座：原生理解图片、视频、设计稿、文档版面等多模态输入，并支持画框、截图、读网页等多模态工具调用，上下文窗口扩展至200k，将Agent的感知-行动链路从纯文本延伸到视觉交互。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"兼顾视觉与编程能力：在多模态Coding、Tool Use、GUI Agent等核心基准上取得领先表现。通过多任务协同RL等技术手段，确保纯文本场景下的编程、推理、工具调用等能力不退化。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"深度适配Claude Code与龙虾场景：与Claude Code、OpenClaw/AutoClaw等Agent深度协同，支持“看懂环境→规划动作→执行任务”的完整闭环，并提供全套官方Skills，开箱即用。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"多模态Coding基座\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"type\":\"heading\",\"version\":1,\"tag\":\"h1\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"在多模态Coding、Agentic任务以及纯文本Coding维度的评测基准上，GLM-5V-Turbo均以更小尺寸取得了领先表现。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"69cf9774f21c2c2005c82ca8\",\"fields\":null,\"relationTo\":\"media\",\"value\":{\"id\":956,\"alt\":\" \",\"updatedAt\":\"2026-04-03T10:33:24.383Z\",\"createdAt\":\"2026-04-03T10:33:24.382Z\",\"url\":\"/api/media/file/download_image.png\",\"thumbnailURL\":null,\"filename\":\"download_image.png\",\"mimeType\":\"image/png\",\"filesize\":165654,\"width\":1080,\"height\":747,\"focalX\":50,\"focalY\":50}},{\"children\":[],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"GLM-5V-Turbo在设计稿还原、视觉代码生成、多模态检索与问答、视觉探查等基准上均取得领先表现；在衡量真实GUI环境操控能力的AndroidWorld、WebVoyager等基准上同样表现突出。在纯文本Coding能力方面，GLM-5V-Turbo在CC-Bench-V2的Backend、Frontend和Repo Exploration三项核心基准测试中均保持稳定表现，表明\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"视觉能力引入后，纯文本编程与推理能力保持了同等水准\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"69cf9787f21c2c2005c82ca9\",\"fields\":null,\"relationTo\":\"media\",\"value\":{\"id\":957,\"alt\":\" \",\"updatedAt\":\"2026-04-03T10:33:43.131Z\",\"createdAt\":\"2026-04-03T10:33:43.130Z\",\"url\":\"/api/media/file/download_image%20(1).png\",\"thumbnailURL\":null,\"filename\":\"download_image (1).png\",\"mimeType\":\"image/png\",\"filesize\":100903,\"width\":1080,\"height\":381,\"focalX\":50,\"focalY\":50}},{\"children\":[],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"在AutoClaw等龙虾Agent中接入GLM-5V-Turbo后，\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"龙虾具备了真正的视觉能力，能看懂屏幕上的信息\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"。模型在衡量龙虾Agent任务执行质量的PinchBench、ClawEval和ZClawBench上取得优异成绩，验证了其在复杂任务执行场景中的综合能力。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"内测阶段，字节跳动、美团、快手等互联网大厂\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"合作伙伴对GLM-5V-Turbo给予了高度评价\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"：\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"“GLM-5V-Turbo实现了从设计稿到代码的完整还原，作为一款视觉理解模型，能够很好地满足开发者的前端开发场景。”——TRAE模型测评团队\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"quote\",\"version\":1},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"“原生多模态能力的引入并未削弱其编程逻辑，其编程能力仍属于国内第一梯队。增强了AI at Work领域下D2C、图片处理等方向的工作体验。”——美团某团队\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"quote\",\"version\":1},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"“它为Agent安上了「眼睛」，同时在编程领域展现出优于同类多模态模型的能力，在视觉编程场景中更具竞争力。”——快手万擎模型测评团队\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"quote\",\"version\":1},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"GLM-5V-Turbo能够取得性能领先在于其\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"模型架构、训练方法、数据构造、工具链四个层面的系统性升级\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"：\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"原生多模态融合：GLM-5V-Turbo从预训练阶段开始进行文本与视觉能力深度融合，并在后训练阶段实现多模态协同优化。我们研发了新一代CogViT视觉编码器，在通用物体识别、细粒度理解、几何与空间感知上均达最优，也设计了兼容多模态输入且推理友好的MTP结构，在多模态场景下实现了较高的推理效率。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"30+ 任务协同强化学习：在强化学习阶段同时优化30+任务类型，覆盖STEM、grounding、video、GUI Agent等子领域，模型在感知、推理、Agentic执行和人类体感上均获稳健提升，协同强化学习有效缓解了单领域训练的不稳定性。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"Agentic数据与任务构造：针对Agent数据稀缺和验证困难的行业挑战，我们构建从元素感知到序列级动作预测的多层级体系，基于合成环境大规模生成可控、可验证的训练数据，并从预训练阶段即注入Agentic元能力（如将GUI Agent PRM数据加入预训练以降低幻觉），同时探索非对称优化，用多模态评估任务撬动更强的Agent能力。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"多模态工具链扩展：在文本工具基础上，GLM-5V-Turbo新增支持多模态搜索、画框、截图、读网页等多模态tools，将编程与任务执行的感知-行动链路从纯文本扩展到视觉交互。与Claude Code、AutoClaw等龙虾的协同效果进一步增强，支持“看懂环境→规划动作→执行任务”的完整闭环。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"典型场景展示\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"heading\",\"version\":1,\"tag\":\"h1\"},{\"children\":[],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"1.图像即代码\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"heading\",\"version\":1,\"tag\":\"h2\"},{\"children\":[],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"GLM-5V-Turbo尤其擅长核心视觉编程场景。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"69cf97b8f21c2c2005c82caa\",\"fields\":null,\"relationTo\":\"media\",\"value\":{\"id\":958,\"alt\":\" \",\"updatedAt\":\"2026-04-03T10:34:32.555Z\",\"createdAt\":\"2026-04-03T10:34:32.554Z\",\"url\":\"/api/media/file/%E6%99%BA%E8%B0%B1-%E9%A2%9D%E5%A4%96Case1-%E4%B8%AD%E6%96%87-0402%20(1).m4v\",\"thumbnailURL\":null,\"filename\":\"智谱-额外Case1-中文-0402 (1).m4v\",\"mimeType\":\"video/mp4\",\"filesize\":40523666,\"width\":null,\"height\":null,\"focalX\":null,\"focalY\":null}},{\"children\":[],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"前端复刻\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"：发送草图、设计稿、参考网站的截图或录屏，模型就能直接理解布局、配色、组件层级与交互逻辑，生成完整可运行的前端工程，准确还原版式、配色、动效等视觉细节。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"GUI自主探索复刻\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"：结合Claude Code等框架，GLM-5V-Turbo能凭借自身强大的GUI Agent能力自主探索目标网站，浏览页面结构、梳理各页面之间的跳转关系、采集视觉素材与交互细节，最后基于记录的探索结果直接生成代码复现整个站点，实现从“看图复刻”到“GUI探索复刻”的能力跃升。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"交互式编辑\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"：支持按需求增删页面模块、修改文案与样式、调整布局结构，并可补充按钮反馈、弹窗切换、表单联动等交互功能，实现可视化迭代编辑。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"2.为龙虾安上眼睛\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"heading\",\"version\":1,\"tag\":\"h2\"},{\"children\":[],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"龙虾的任务边界被大幅拓宽\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"，例如可以浏览网页和文档，生成图文并茂的报告、PPT，还可以查询并解读K线图等复杂图表。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":1,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"AutoClaw已上线“股票分析师”Skill，利用GLM-5V-Turbo的原生视觉能力，龙虾能直接看懂K线走势、估值区间图和券商研报图表，实现四路数据源60秒并行采集，输出\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"图文交错\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"的研报。立即在AutoClaw中\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"切换至GLM-5V-Turbo\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"，试试提问“帮我分析今天XXX的股价，生成专业分析报告”。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"除视觉编程与龙虾任务外，GLM-5V-Turbo在多模态搜索、深度研究、GUI Agent、感知Grounding等更广泛的Agentic场景中也实现了显著的性能提升。为此，我们提供了一组\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"官方Skills\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"，涵盖图像Captioning、视觉Grounding、基于文档的写作、简历筛选、提示词生成等原生能力，以及基于GLM-OCR和GLM-Image构建的文字识别、表格识别、手写体识别、公式识别和文生图能力，帮助用户在更多场景中释放模型的多模态潜力。上述Skills已上线ClawHub，一键安装即可体验全部能力。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"ClawHub链接\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"：\",\"type\":\"text\",\"version\":1},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"https://clawhub.ai/zai-org/glm-master-skill\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"type\":\"link\",\"version\":3,\"fields\":{\"url\":\"https://clawhub.ai/zai-org/glm-master-skill\",\"newTab\":true,\"linkType\":\"custom\"},\"id\":\"69d8a70049068ea474ee78c4\"}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"GitHub链接：\",\"type\":\"text\",\"version\":1},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"https://github.com/zai-org/GLM-skills\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"type\":\"link\",\"version\":3,\"fields\":{\"url\":\"https://github.com/zai-org/GLM-skills\",\"newTab\":true,\"linkType\":\"custom\"},\"id\":\"69d8a75849068ea474ee78c5\"}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"立即体验\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"\",\"indent\":0,\"type\":\"heading\",\"version\":1,\"tag\":\"h1\"},{\"children\":[],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"欢迎广大用户通过以下方式接入GLM-5V-Turbo：\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"1.产品体验\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"heading\",\"version\":1,\"tag\":\"h3\"},{\"children\":[],\"direction\":null,\"format\":\"\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"AutoClaw（澳龙）：https://autoglm.zhipuai.cn/autoclaw/\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"Z.ai：https://chat.z.ai\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"2.官方API接入\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"heading\",\"version\":1,\"tag\":\"h3\"},{\"children\":[],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"BigModel\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\" 开放平台\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"：https://docs.bigmodel.cn/cn/guide/models/vlm/glm-5v-turbo\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"Z.ai：https://docs.z.ai/guides/vlm/glm-5v-turbo\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"Coding Plan：现面向Coding Plan用户开放申请；后续GLM Coding Plan也会纳入GLM-5V-Turbo，敬请期待。申请问卷：https://zhipu-ai.feishu.cn/share/base/form/shrcndgpmRlJoD5rMmIavUrPwzg\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"69cf9827f21c2c2005c82cab\",\"fields\":null,\"relationTo\":\"media\",\"value\":{\"id\":959,\"alt\":\" \",\"updatedAt\":\"2026-04-03T10:36:23.345Z\",\"createdAt\":\"2026-04-03T10:36:23.344Z\",\"url\":\"/api/media/file/da5d94bc5f15e2975fc6f4b5468036c8.png\",\"thumbnailURL\":null,\"filename\":\"da5d94bc5f15e2975fc6f4b5468036c8.png\",\"mimeType\":\"image/png\",\"filesize\":588642,\"width\":1170,\"height\":1449,\"focalX\":50,\"focalY\":50}},{\"children\":[],\"direction\":null,\"format\":\"\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"}],\"direction\":null,\"format\":\"\",\"indent\":0,\"type\":\"root\",\"version\":1}},\"contentType_en\":\"content\",\"externalUrl_en\":null,\"content_en\":null,\"featured\":false,\"thumbnail_zh\":null,\"thumbnail_en\":null,\"active\":true,\"order\":0,\"tag_zh\":[\"基座模型\"],\"tag_en\":[\"Mutimodal AI\"],\"apiConfig_zh\":null,\"apiConfig_en\":null,\"experienceUrl_zh\":null,\"experienceUrl_en\":null,\"updatedAt\":\"2026-04-21T04:52:36.490Z\",\"createdAt\":\"2026-04-03T10:36:51.645Z\"},\"title_zh\":\"GLM-5V-Turbo\",\"title_en\":\"GLM-5V-Turbo\",\"desc_zh\":\"面向视觉编程打造的多模态Coding基座模型\",\"desc_en\":\"Multimodal Coding Model\",\"showNew\":true,\"active\":true,\"order\":1,\"updatedAt\":\"2026-04-20T03:51:02.522Z\",\"createdAt\":\"2026-03-19T12:48:26.455Z\"},{\"id\":1,\"article\":{\"id\":155,\"title_zh\":\"GLM-5-Turbo：龙虾增强的基座模型\",\"title_en\":\"GLM-5-Turbo: A Foundation Model Enhanced for OpenClaw\",\"createAt\":\"2026-03-15T16:00:00.000Z\",\"category\":\"blog\",\"resume_zh\":null,\"resume_en\":\"A foundation model for OpenClaw\",\"contentType_zh\":\"content\",\"externalUrl_zh\":null,\"content_zh\":{\"root\":{\"children\":[{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"我们推出GLM-5-Turbo——一个面向OpenClaw龙虾场景深度优化的基座模型。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"体验过OpenClaw的用户都有一个共同感受：模型能聊好天，但未必能干好活。问题的根源不在框架，而在底层模型本身。通用大模型在进入真实复杂的Agent场景后，容易在长链路任务中失速。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"Harness再多，不如模型自身变强。GLM-5-Turbo从训练阶段就针对龙虾任务的核心需求进行专项优化，增强如工具调用、指令遵循、定时与持续性任务、长链路执行等核心能力。\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"在自研基准测试ZClawBench中取得国产模型第一的成绩\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"；多家互联网大厂在龙虾场景内测中给予高度评价。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"我们推出\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"Claw龙虾套餐\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"，及面向企业级场景的Claw安全管理体系。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"龙虾原生模型\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"heading\",\"version\":1,\"textFormat\":1,\"tag\":\"h1\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"龙虾任务不是简单的一问一答，通常涉及多轮理解、任务拆解、工具调用、状态衔接、时间触发和持续执行的长链路工作流。\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"通用模型\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"即使在对话能力上表现优秀，一旦进入真实龙虾场景，仍然容易出现指令遵循偏差、工具调用不稳定、长任务中途失速等问题。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"要从根本上解决这些难题，\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"必须在基座模型层进行深度优化\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"——这正是GLM-5-Turbo的出发点。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"从训练数据构造到优化目标设计，我们构造真实Agent工作流使模型在龙虾任务中具备可执行性。重点增强以下核心能力：\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"Tool Calling——调用不掉链子。强化对外部工具与各类Skills的调用能力。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"Instruction Following——复杂指令拆解更强。对复杂多层、长链路指令理解和拆解更准确，支持识别目标、规划步骤、多智能体协同。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"定时与持续性任务——更懂时间维度，长任务不中断。针对定时触发、长时间运行等场景进行重点优化，能够更好理解时间维度上的要求。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"高吞吐长链路——执行更稳。针对数据吞吐量大、链条长的任务进一步提升执行效率与稳定性，适合长程业务流程。\",\"type\":\"text\",\"version\":1},{\"type\":\"linebreak\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"龙虾场景基准ZClawBench\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"heading\",\"version\":1,\"textFormat\":1,\"tag\":\"h1\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"随着龙虾OpenClaw的普及，如何评测模型在龙虾场景的能力成为全行业焦点。基于对OpenClaw大量真实用例的分析，我们发布龙虾场景端到端Agent评测基准ZClawBench。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"当前OpenClaw的任务类型覆盖安装配置、代码开发、信息搜集、数据分析、内容创作等多元化任务，用户群体也从早期的开发者扩展到效率办公人群、金融从业者、运维工程师、内容创作者与研究分析人员等。同时，\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"Skills的使用比例在短时间内从26%快速增长至45%\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"，表明Agent能力正向模块化与技能化的生态方向演进。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"基于该基准的评测结果显示，\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"GLM-5-Turbo在OpenClaw场景中的表现相比GLM-5提升显著，在多项关键任务上整体领先于多家主流模型。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"69cf95dff21c2c2005c82c9d\",\"fields\":null,\"relationTo\":\"media\",\"value\":{\"id\":951,\"alt\":\" \",\"updatedAt\":\"2026-04-03T10:26:39.011Z\",\"createdAt\":\"2026-04-03T10:26:39.009Z\",\"url\":\"/api/media/file/111.png\",\"thumbnailURL\":null,\"filename\":\"111.png\",\"mimeType\":\"image/png\",\"filesize\":1194870,\"width\":3255,\"height\":2270,\"focalX\":50,\"focalY\":50}},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"ZClawBench的题库与测试轨迹已全面公开，欢迎业界共同验证与完善。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"用户真实体验是试金石。GLM-5-Turbo以Pony-Alpha-2为代号接入AutoClaw澳龙，在用户盲测中，\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"90%\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"的受访者认为GLM-5-Turbo的表现优于其他国产模型。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"内测阶段，\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"龙虾生态的互联网大厂对GLM-5-Turbo给予高度评价\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"：\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"“精准的工具调用配合长程任务的稳定可靠，完美驱动了桌面级Agent上的跨应用数据流转与系统API操控。在攻克办公场景的‘幻觉’痛点上表现优秀！”——阿里QoderWork模型测评团队\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"quote\",\"version\":1},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"“指令遵循力压群雄，面对长任务更精准不掉链子，极大提升了多智能体构建的成功率。”——扣子Coze测评团队\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"quote\",\"version\":1},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"“定时与长链路任务稳健，对比同类模型展现出明显第一梯队的优势，非常靠谱。”——美团某团队\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"quote\",\"version\":1},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"“高吞吐执行极快且不失速，响应稳定性领跑同类模型，真正解决了Agent的执行难题。”——快手万擎测评团队\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"quote\",\"version\":1},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"在编程场景，GLM-5-Turbo延续GLM模型\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"Agentic Engineering\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"的表现：\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"“编程能力稳居第一梯队，在Coding Agent实测中优于同类模型，处理长链路代码任务非常稳健。”——字节TRAE团队\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"quote\",\"version\":1},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"GLM-5-Turbo已接入软通动力旗下机械革命盒子中，\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"面向全球首发接入GLM模型的机械革命“龙虾盒子”\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"，打造原生AI Agent终端体验。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"69cf95f3f21c2c2005c82c9e\",\"fields\":null,\"relationTo\":\"media\",\"value\":{\"id\":952,\"alt\":\" \",\"updatedAt\":\"2026-04-03T10:26:59.699Z\",\"createdAt\":\"2026-04-03T10:26:59.698Z\",\"url\":\"/api/media/file/222.png\",\"thumbnailURL\":null,\"filename\":\"222.png\",\"mimeType\":\"image/png\",\"filesize\":1412232,\"width\":1932,\"height\":810,\"focalX\":50,\"focalY\":50}},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"龙虾套餐喂饱你的AI同事\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"heading\",\"version\":1,\"textFormat\":1,\"tag\":\"h1\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"龙虾太能干活，自然也吃tokens。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"一个典型的龙虾任务，比如完成一次跨部门的会议纪要整理与任务分发，可能涉及数十轮工具调用与上下文衔接，tokens消耗远超普通对话。对于使用龙虾的企业和个人来说，tokens成为最大的成本瓶颈。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"为了让企业和个人实现龙虾“tokens自由”，智谱即日起推出基于GLM-5-Turbo的龙虾套餐，包含个人版和Team版。无论你是一人公司、创业团队，或者是大中型企业，都能根据自身业务规模灵活订阅套餐。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"69cf9609f21c2c2005c82c9f\",\"fields\":null,\"relationTo\":\"media\",\"value\":{\"id\":953,\"alt\":\" \",\"updatedAt\":\"2026-04-03T10:27:21.208Z\",\"createdAt\":\"2026-04-03T10:27:21.208Z\",\"url\":\"/api/media/file/333-2.png\",\"thumbnailURL\":null,\"filename\":\"333-2.png\",\"mimeType\":\"image/png\",\"filesize\":312315,\"width\":1280,\"height\":604,\"focalX\":50,\"focalY\":50}},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"每个账号最多购买5个。企业可通过龙虾套餐Team版，按照实际员工数灵活订阅，以可控成本实现tokens的充分保障以及AI员工的稳定在线。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"此外，我们在龙虾套餐的基础上，专门构建了\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"一套面向企业级场景的OpenClaw安全管理体系“Claw for Enterprise Security”\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"。支持对不同类型Claw的统一调度与权限编排——无论是信息搜集、数据分析、代码开发还是跨系统操作，企业可以根据业务流程灵活组合Claw能力，并通过集中化的管控台对每一个Agent任务的执行路径、工具调用链路和资源消耗进行实时可视化监控，让复杂的多Agent协同不再是黑盒。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"在安全保障层面，该系统提供多层防护机制\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"：基于角色的权限管理确保每个Claw只能在授权范围内调用工具和访问数据；所有操作均生成完整的审计日志，满足企业合规要求；敏感业务数据全程加密处理，严格遵守数据本地化要求，不离开企业可控边界；关键业务节点保留人工审批机制，防止自动化流程产生不可控的业务风险。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":1,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"正在到来的变革是，以OpenClaw为代表的Agent正在进入组织内部，让每一家企业都拥有7×24小时在线、随叫随到的AI员工；同时，它们也成为我们每个人的专属AI助理，把人从流程化、重复性的琐事中真正解放出来。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"我们正在见证大模型从提效工具，走向企业劳动力的一场关键跃迁。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"接入与使用\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"heading\",\"version\":1,\"textFormat\":1,\"tag\":\"h1\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"GLM-5-Turbo现已上线，开发者和企业用户可以通过智谱开放平台\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"BigModel.cn\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"直接调用API，或者通过龙虾套餐接入。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"GLM Coding Plan Max现已支持GLM-5-Turbo，Pro套餐将在本月尽快支持，Lite套餐将在4月支持接入。Coding Plan也可用于OpenClaw接入体验；如需长期稳定运行、后台持续执行或更高负载的Agent场景，建议优先使用龙虾套餐。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"GLM-5、GLM-5-Turbo作为对标Claude Opus的高阶模型，将按照“高峰期3倍，非高峰期2倍”系数消耗额度。作为限时福利，\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"GLM-5-Turbo将在非高峰期仅作1倍抵扣持续到4月底。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"AutoClaw澳龙默认模型为GLM-5-Turbo，让所有非程序员群体可以体验GLM-5-Turbo龙虾能力，享受一定免费额度。即日起至3月22日为澳龙限时福利，加油包最高享3.4折优惠（加油包自购买起7日内有效）。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"69cf964af21c2c2005c82ca0\",\"fields\":null,\"relationTo\":\"media\",\"value\":{\"id\":954,\"alt\":\" \",\"updatedAt\":\"2026-04-03T10:28:26.424Z\",\"createdAt\":\"2026-04-03T10:28:26.423Z\",\"url\":\"/api/media/file/444.png\",\"thumbnailURL\":null,\"filename\":\"444.png\",\"mimeType\":\"image/png\",\"filesize\":63251,\"width\":1706,\"height\":540,\"focalX\":50,\"focalY\":50}},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"官方 API 接入\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"heading\",\"version\":1,\"textFormat\":1,\"tag\":\"h2\"},{\"children\":[],\"direction\":null,\"format\":\"\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"智谱开放平台：BigModel.cn\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"Z.ai：api.z.ai\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"GLM Coding Plan\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"heading\",\"version\":1,\"textFormat\":1,\"tag\":\"h2\"},{\"children\":[],\"direction\":null,\"format\":\"\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"Coding Plan Max已纳入GLM-5-Turbo\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"Pro版将在本月尽快支持\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"在线体验\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"heading\",\"version\":1,\"textFormat\":1,\"tag\":\"h2\"},{\"children\":[],\"direction\":null,\"format\":\"\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"AutoClaw澳龙客户端：\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"https://autoglm.zhipuai.cn/autoclaw\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"Z.ai：z.ai\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"智谱清言APP/网页版\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"start\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"}],\"direction\":null,\"format\":\"\",\"indent\":0,\"type\":\"root\",\"version\":1}},\"contentType_en\":\"content\",\"externalUrl_en\":null,\"content_en\":null,\"featured\":true,\"thumbnail_zh\":null,\"thumbnail_en\":null,\"active\":true,\"order\":0,\"tag_zh\":[\"基座模型\",\"Agent\"],\"tag_en\":[\"Agentic LLM\"],\"apiConfig_zh\":null,\"apiConfig_en\":null,\"experienceUrl_zh\":null,\"experienceUrl_en\":null,\"updatedAt\":\"2026-04-21T04:54:19.553Z\",\"createdAt\":\"2026-04-03T10:29:20.932Z\"},\"title_zh\":\"GLM-5-Turbo\",\"title_en\":\"GLM-5-Turbo\",\"desc_zh\":\"专为龙虾场景打造的基座模型\",\"desc_en\":\"Built for Claw\",\"showNew\":true,\"active\":true,\"order\":2,\"updatedAt\":\"2026-04-20T03:55:54.590Z\",\"createdAt\":\"2026-03-19T12:45:35.934Z\"},{\"id\":3,\"article\":{\"id\":158,\"title_zh\":\"智谱联合华为开源首个国产芯片训练的多模态SOTA模型\",\"title_en\":\"GLM-Image: Auto-regressive for  Dense-knowledge and High-fidelity  Image Generation\",\"createAt\":\"2026-01-13T16:00:00.000Z\",\"category\":\"blog\",\"resume_zh\":null,\"resume_en\":\"the first open-source, industrial-grade discrete auto-regressive image generation model\",\"contentType_zh\":\"content\",\"externalUrl_zh\":null,\"content_zh\":{\"root\":{\"children\":[{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"今天，智谱联合华为开源新一代图像生成模型\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"GLM-Image\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"，模型基于昇腾Atlas 800T A2设备和昇思MindSpore AI框架完成从数据到训练的全流程，是\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"首个在国产芯片上完成全程训练的SOTA多模态模型\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"GLM-Image采用自主创新的「自回归+扩散解码器」混合架构，实现了图像生成与语言模型的联合，\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"是我们面向以Nano Banana Pro为代表的新一代「认知型生成」技术范式的一次重要探索\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"核心亮点如下：\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"架构革新，面向「认知型生成」的技术探索：采用创新的「自回归 + 扩散编码器」混合架构，兼顾全局指令理解与局部细节刻画，克服了海报、PPT、科普图等知识密集型场景生成难题，向探索以Nano Banana Pro为代表的新一代“知识+推理”的认知型生成模型迈出了重要一步。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"listitem\",\"version\":1,\"value\":1},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"首个在国产芯片完成全程训练的SOTA模型：模型自回归结构基座基于昇腾Atlas 800T A2设备与昇思MindSpore AI框架，完成了从数据预处理到大规模训练的全流程构建，验证了在国产全栈算力底座上训练前沿模型的可行性。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"listitem\",\"version\":1,\"value\":2},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"文字渲染开源SOTA：在CVTG-2K（复杂视觉文本生成）和LongText-Bench（长文本渲染）榜单获得开源第一，\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"尤其擅长汉字生成任务\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"listitem\",\"version\":1,\"value\":3},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"高性价比与速度优化：API调用模式下，生成一张图片\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"仅需0.1元\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"，速度优化版本即将更新。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"listitem\",\"version\":1,\"value\":4}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"list\",\"version\":1,\"listType\":\"bullet\",\"start\":1,\"tag\":\"ul\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"架构创新：读懂指令，写对文字\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"heading\",\"version\":1,\"tag\":\"h2\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"近期，以\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"Nano Banana Pro\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"为代表的闭源图像生成模型正在推动图像生成与大语言模型的深度融合。\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"技术范式正从单一的图像生成，进化为兼具世界知识与推理能力的「认知型生成」\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"。这些模型在海报、PPT、科普图等知识密集型场景及高保真细节呈现上表现惊艳，展现了这一技术范式的优势。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"GLM-Image正是我们面向「认知型生成」技术范式一次重要探索。这是首个开源的工业表现级离散自回归图像生成模型，\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"我们希望借此与开源社区分享我们在这一前沿方向的技术路径与实践思考\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"创新架构让模型读懂写对：面对传统模型在“理解复杂指令”与“精准绘制文字”上难以兼顾的问题，GLM-Image 引入了「自回归+扩散解码器」混合架构，创新地融合了9B大小的自回归模型与7B大小的DiT扩散解码器。前者利用其语言模型的底座优势，专注于提升对指令的语义理解和画面的全局构图；后者配合Glyph Encoder的文本编码器，专注于还原图像的高频细节和文字笔画，以此改善模型“提笔忘字”的现象。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"listitem\",\"version\":1,\"value\":1},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"多分辨率自适应：通过改进Tokenizer策略，GLM-Image能够自适应处理多种分辨率，原生支持从1024x1024到2048×2048尺寸的任意比例图像的生成任务，无需重新训练。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"listitem\",\"version\":1,\"value\":2}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"list\",\"version\":1,\"listType\":\"bullet\",\"start\":1,\"tag\":\"ul\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"69e5af6adca8453370f68fbb\",\"fields\":null,\"relationTo\":\"media\",\"value\":{\"id\":966,\"alt\":\" \",\"updatedAt\":\"2026-04-20T04:28:44.916Z\",\"createdAt\":\"2026-04-20T04:28:44.915Z\",\"url\":\"/api/media/file/1-2.webp\",\"thumbnailURL\":null,\"filename\":\"1-2.webp\",\"mimeType\":\"image/webp\",\"filesize\":20036,\"width\":1080,\"height\":265,\"focalX\":50,\"focalY\":50}},{\"children\":[{\"detail\":0,\"format\":2,\"mode\":\"normal\",\"style\":\"\",\"text\":\"通用pipeline\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":2,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"69e5af7cdca8453370f68fbc\",\"fields\":null,\"relationTo\":\"media\",\"value\":{\"id\":967,\"alt\":\" \",\"updatedAt\":\"2026-04-20T04:28:59.459Z\",\"createdAt\":\"2026-04-20T04:28:59.459Z\",\"url\":\"/api/media/file/2-2.webp\",\"thumbnailURL\":null,\"filename\":\"2-2.webp\",\"mimeType\":\"image/webp\",\"filesize\":24028,\"width\":1080,\"height\":411,\"focalX\":50,\"focalY\":50}},{\"children\":[{\"detail\":0,\"format\":2,\"mode\":\"normal\",\"style\":\"\",\"text\":\"解码器结构示意图\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":2,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"开源SOTA：更擅长文字密集生成任务\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"heading\",\"version\":1,\"tag\":\"h2\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"基于上述架构创新，GLM-Image在文字渲染的权威榜单中达到开源SOTA水平。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"69e5af94dca8453370f68fbd\",\"fields\":null,\"relationTo\":\"media\",\"value\":{\"id\":968,\"alt\":\" \",\"updatedAt\":\"2026-04-20T04:35:49.320Z\",\"createdAt\":\"2026-04-20T04:35:49.319Z\",\"url\":\"/api/media/file/3-2.webp\",\"thumbnailURL\":null,\"filename\":\"3-2.webp\",\"mimeType\":\"image/webp\",\"filesize\":25520,\"width\":1080,\"height\":436,\"focalX\":50,\"focalY\":50}},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"children\":[{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"CVTG-2K（复杂视觉文字生成）\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"榜单核心考察模型在图像中同时生成多处文字的准确性。在多区域文字生成准确率上，GLM-Image凭借0.9116的Word Accuracy（文字准确率）成绩，位列开源模型第一。在NED（归一化编辑距离）指标上，GLM-Image同样以0.9557领先，表明其生成的文字与目标文字高度一致，错字、漏字情况更少。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"listitem\",\"version\":1,\"textFormat\":1,\"value\":1},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"LongText-Bench（长文本渲染）榜单考察模型渲染长文本、多行文字的准确性，覆盖招牌、海报、PPT、对话框等8种文字密集场景，并分设中英双语测试，GLM-Image以英文0.952、中文0.979的成绩位列开源模型第一。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"listitem\",\"version\":1,\"value\":2}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"list\",\"version\":1,\"listType\":\"bullet\",\"start\":1,\"tag\":\"ul\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"首个国产芯片训练出的SOTA模型\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"heading\",\"version\":1,\"tag\":\"h2\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"GLM-Image是我们对国产计算生态的一次深度探索与验证。其自回归结构基座从早期的数据预处理到最终的大规模预训练，全流程均在昇腾Atlas 800T A2设备上完成。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"依托昇腾NPU和昇思MindSpore AI框架，使用动态图多级流水下发、高性能融合算子、多流并行等特性，我们自研了模型训练套件，全面优化数据预处理、预训练、SFT和RL的端到端流程。通过动态图的多级流水优化机制，将Host侧算子下发的关键阶段流水化并高度重叠，消除下发瓶颈；通过多流并行策略，通信和计算互掩，打破文本梯度同步、图像特征广播等操作的通信墙，极致优化性能；使用AdamW EMA、COC、RMS Norm等昇腾亲和的高性能融合算子，同步提升训练的稳定性和性能。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"GLM-Image是首个在国产芯片上完成全流程训练的SOTA多模态模型，\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":1,\"mode\":\"normal\",\"style\":\"\",\"text\":\"验证了在国产全栈算力底座上训练高性能多模态生成模型的可行性\",\"type\":\"text\",\"version\":1},{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"。我们希望这一实践能为社区挖掘国产算力潜力提供有价值的参考。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"69e5afafdca8453370f68fbe\",\"fields\":null,\"relationTo\":\"media\",\"value\":{\"id\":969,\"alt\":\" \",\"updatedAt\":\"2026-04-20T04:36:23.915Z\",\"createdAt\":\"2026-04-20T04:36:23.915Z\",\"url\":\"/api/media/file/4-2.webp\",\"thumbnailURL\":null,\"filename\":\"4-2.webp\",\"mimeType\":\"image/webp\",\"filesize\":40456,\"width\":1080,\"height\":471,\"focalX\":50,\"focalY\":50}},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"实测案例\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"heading\",\"version\":1,\"tag\":\"h2\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"让我们来看看GLM-Image在实际的复杂图文任务中的表现。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"场景一：科普插画\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"GLM-Image 更擅长绘制包含复杂逻辑流程与文字说明的科普插画及原理示意图。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"69e5afc2dca8453370f68fbf\",\"fields\":null,\"relationTo\":\"media\",\"value\":{\"id\":970,\"alt\":\" \",\"updatedAt\":\"2026-04-20T04:37:01.387Z\",\"createdAt\":\"2026-04-20T04:37:01.386Z\",\"url\":\"/api/media/file/5-2.webp\",\"thumbnailURL\":null,\"filename\":\"5-2.webp\",\"mimeType\":\"image/webp\",\"filesize\":97304,\"width\":1080,\"height\":684,\"focalX\":50,\"focalY\":50}},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"69e5afcadca8453370f68fc0\",\"fields\":null,\"relationTo\":\"media\",\"value\":{\"id\":971,\"alt\":\" \",\"updatedAt\":\"2026-04-20T04:37:15.244Z\",\"createdAt\":\"2026-04-20T04:37:15.243Z\",\"url\":\"/api/media/file/6-1.webp\",\"thumbnailURL\":null,\"filename\":\"6-1.webp\",\"mimeType\":\"image/webp\",\"filesize\":107422,\"width\":1080,\"height\":684,\"focalX\":50,\"focalY\":50}},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"场景二：多格图画\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"在生成电商图、漫画等多格图画时，GLM-Image能够保持风格和主体的一致性，并保障多处文字生成的准确率。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\":\"upload\",\"version\":3,\"format\":\"\",\"id\":\"69e5afd7dca8453370f68fc1\",\"fields\":null,\"relationTo\":\"media\",\"value\":{\"id\":972,\"alt\":\" \",\"updatedAt\":\"2026-04-20T04:37:37.777Z\",\"createdAt\":\"2026-04-20T04:37:37.776Z\",\"url\":\"/api/media/file/7-1.webp\",\"thumbnailURL\":null,\"filename\":\"7-1.webp\",\"mimeType\":\"image/webp\",\"filesize\":91728,\"width\":1080,\"height\":616,\"focalX\":50,\"focalY\":50}},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"场景三：社交媒体图文封面\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[{\"detail\":0,\"format\":0,\"mode\":\"normal\",\"style\":\"\",\"text\":\"GLM-Image 适用于制作社交媒体封面及内容等排版复杂的图片，让您的创作更自由丰富。\",\"type\":\"text\",\"version\":1}],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"children\":[],\"direction\":null,\"format\":\"justify\",\"indent\":0,\"type\":\"paragraph\",\"version\":1,\"textFormat\":0,\"textStyle\":\"\"},{\"type\