{
  "name": "benchforge-desktop",
  "version": "0.2.0",
  "private": true,
  "description": "BenchForge desktop app powered by Electron, React, TypeScript and Vite.",
  "author": "BenchForge",
  "license": "MIT",
  "main": "electron/main.cjs",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "install:frontend": "cd frontend && npm install",
    "build": "cd frontend && npm run build",
    "desktop": "electron .",
    "start": "npm run build && electron .",
    "dist": "npm run dist:win",
    "dist:win": "npm run build && electron-builder --win nsis portable zip --publish never",
    "pack": "npm run build && electron-builder --dir",
    "checksum": "node scripts/checksums.cjs release",
    "release:win": "npm run dist:win && npm run checksum"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "electron": "^35.1.4",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.benchforge.desktop",
    "productName": "BenchForge",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "BenchForge-${version}-${arch}.${ext}"
    },
    "nsis": {
      "artifactName": "BenchForge-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "displayLanguageSelector": true,
      "multiLanguageInstaller": true,
      "installerLanguages": [
        "en_US",
        "pl_PL",
        "de_DE",
        "es_ES"
      ],
      "include": "build/installer.nsh",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "BenchForge-Portable-${version}-${arch}.${ext}"
    }
  }
}
